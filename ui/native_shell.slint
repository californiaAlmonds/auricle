import { LineEdit } from "std-widgets.slint";

struct SongItem {
    video-id: string,
    title: string,
    artist: string,
    album: string,
    duration-str: string,
    avatar-letter: string,
    duration-secs: int,
    thumbnail: image,
    has-thumbnail: bool,
}

struct ArtistItem {
    name: string,
    browse-id: string,
    thumbnail: image,
    has-thumbnail: bool,
    subscriber-count: string,
}

struct AlbumItem {
    title: string,
    browse-id: string,
    artist: string,
    year: string,
    thumbnail: image,
    has-thumbnail: bool,
}

struct PlaylistItem {
    title: string,
    playlist-id: string,
    thumbnail: image,
    has-thumbnail: bool,
    count-text: string,
}

struct MoodItem {
    title: string,
    params: string,
}

// ─── Shared components ────────────────────────────────────────────────────────

component IconBtn inherits Rectangle {
    in property <string> icon;
    in property <color> icon-color: #8a8a8a;
    in property <bool> active: false;
    in property <image> svg-icon;
    in property <bool> use-svg: false;
    callback clicked();
    width: 36px; height: 36px; border-radius: 8px;
    background: ta.has-hover ? #ffffff14 : (active ? #ffffff0c : transparent);
    if !use-svg: Text {
        text: root.icon;
        color: ta.has-hover ? #ffffff : (root.active ? #ffffff : root.icon-color);
        font-size: 18px;
        horizontal-alignment: center; vertical-alignment: center;
    }
    if use-svg: Image {
        source: root.svg-icon;
        width: 20px; height: 20px;
        colorize: ta.has-hover ? #ffffff : (root.active ? #ffffff : root.icon-color);
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

// Slim progress bar for add-on installs. `value` in 0.0..=1.0 shows a determinate
// fill; a negative `value` shows an indeterminate sliding segment.
component AddonProgress inherits Rectangle {
    in property <float> value: 0.0;
    property <bool> indeterminate: root.value < 0.0;
    property <bool> anim-toggle: false;
    height: 6px; border-radius: 3px; background: #2a2a2a;
    clip: true;

    // Determinate fill
    if !root.indeterminate: Rectangle {
        x: 0; y: 0; height: parent.height; border-radius: 3px;
        width: parent.width * max(0.0, min(1.0, root.value));
        background: #e85d5d;
        animate width { duration: 120ms; easing: ease-out; }
    }

    // Indeterminate sliding segment
    if root.indeterminate: Rectangle {
        y: 0; height: parent.height; border-radius: 3px;
        width: parent.width * 0.35;
        background: #e85d5d;
        x: root.anim-toggle ? (parent.width - self.width) : 0px;
        animate x { duration: 900ms; easing: ease-in-out; }
    }
    timer := Timer {
        interval: 900ms;
        running: root.indeterminate;
        triggered => { root.anim-toggle = !root.anim-toggle; }
    }
}

component NavBtn inherits Rectangle {
    in property <string> label; in property <image> nav-icon; in property <bool> active;
    callback clicked();
    height: 44px; border-radius: 8px;
    background: ta.has-hover ? #ffffff0c : (active ? #ffffff0a : transparent);
    animate background { duration: 100ms; }
    HorizontalLayout {
        padding-left: 14px; padding-right: 14px; padding-top: 11px; padding-bottom: 11px; spacing: 14px; alignment: start;
        Image {
            source: root.nav-icon; width: 22px; height: 22px;
            colorize: root.active ? #ffffff : #7a7a7a;
            vertical-alignment: center;
        }
        Text { text: root.label; font-size: 15px; font-weight: root.active ? 700 : 500; color: root.active ? #ffffff : #b0b0b0; vertical-alignment: center; }
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

component TabPill inherits Rectangle {
    in property <string> label; in property <bool> active;
    callback clicked();
    height: 32px; border-radius: 16px;
    background: active ? #ffffff14 : (ta.has-hover ? #ffffff08 : transparent);
    border-color: active ? #ffffff20 : transparent; border-width: 1px;
    HorizontalLayout {
        padding-left: 14px; padding-right: 14px;
        Text {
            text: root.label; font-size: 13px; font-weight: root.active ? 700 : 500;
            color: root.active ? #ffffff : #909090;
            horizontal-alignment: center; vertical-alignment: center;
        }
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

component SongRow inherits Rectangle {
    in property <string> song-title; in property <string> song-artist;
    in property <string> song-album; in property <string> song-duration;
    in property <string> idx-str; in property <bool> is-current;
    in property <string> avatar-letter: "";
    in property <image> thumbnail;
    in property <bool> has-thumbnail: false;
    in property <bool> show-unlike: false;
    callback play-clicked(); callback queue-clicked(); callback play-next-clicked(); callback dislike-clicked(); callback unlike-clicked();
    callback song-radio-clicked();
    callback go-to-artist-clicked();
    callback go-to-album-clicked();
    height: 64px; border-radius: 8px;
    background: ta.has-hover ? #ffffff0a : (is-current ? #ffffff08 : transparent);
    animate background { duration: 80ms; }
    HorizontalLayout {
        padding-left: 12px; padding-right: 14px; spacing: 12px;
        // Thumbnail or letter avatar
        Rectangle {
            width: 48px; height: 48px; border-radius: 6px; clip: true;
            background: #1a1a1a;
            if has-thumbnail: Image {
                source: thumbnail; width: parent.width; height: parent.height; image-fit: cover;
            }
            if !has-thumbnail: Text {
                text: is-current ? "▶" : (avatar-letter == "" ? root.idx-str : avatar-letter);
                color: is-current ? #e85d5d : #5a5a5a;
                font-size: is-current ? 12px : 13px;
                font-weight: 700; horizontal-alignment: center; vertical-alignment: center;
            }
            // Playing overlay
            if is-current && has-thumbnail: Rectangle {
                width: parent.width; height: parent.height;
                background: #00000066;
                Text { text: "▶"; color: #ffffff; font-size: 14px; horizontal-alignment: center; vertical-alignment: center; }
            }
        }
        // Title + artist
        VerticalLayout {
            alignment: center; spacing: 3px; horizontal-stretch: 1;
            Text {
                text: root.song-title;
                font-size: 14px; font-weight: 500;
                color: is-current ? #e85d5d : #e0e0e0;
                overflow: elide;
            }
            Text {
                text: root.song-album == "" ? root.song-artist
                    : root.song-artist + "  •  " + root.song-album;
                font-size: 12px; color: #6a6a6a; overflow: elide;
            }
        }
        // Duration / "+ Queue" on hover
        Rectangle {
            width: 64px;
            if !ta.has-hover: Text {
                text: root.song-duration;
                font-size: 12px; color: #4a4a4a;
                horizontal-alignment: right; vertical-alignment: center;
            }
            if ta.has-hover: Rectangle {
                width: 56px; height: 28px; border-radius: 14px;
                background: qa.has-hover ? #ffffff18 : #ffffff0c;
                Text { text: "+ Queue"; color: #b0b0b0; font-size: 10px; font-weight: 600;
                    horizontal-alignment: center; vertical-alignment: center; }
                qa := TouchArea { clicked => { root.queue-clicked(); } }
            }
        }
    }
    ta := TouchArea {
        clicked => { root.play-clicked(); }
        pointer-event(e) => {
            if e.button == PointerEventButton.right && e.kind == PointerEventKind.up {
                row-ctx-popup.show();
            }
        }
    }

    row-ctx-popup := PopupWindow {
        x: 60px; y: 10px;
        width: 220px;
        Rectangle {
            width: 220px;
            border-radius: 8px; background: #282828;
            drop-shadow-blur: 16px; drop-shadow-color: #00000080; drop-shadow-offset-y: 4px;
            VerticalLayout {
                padding: 6px;
                Rectangle {
                    height: 38px; border-radius: 4px;
                    background: rctx1.has-hover ? #ffffff14 : transparent;
                    HorizontalLayout {
                        padding-left: 14px; spacing: 12px; alignment: start;
                        Text { text: "+"; font-size: 18px; color: #b0b0b0; vertical-alignment: center; width: 20px; }
                        Text { text: "Add to queue"; font-size: 14px; font-weight: 500; color: #e0e0e0; vertical-alignment: center; }
                    }
                    rctx1 := TouchArea { clicked => { root.queue-clicked(); row-ctx-popup.close(); } }
                }
                Rectangle {
                    height: 38px; border-radius: 4px;
                    background: rctx-pn.has-hover ? #ffffff14 : transparent;
                    HorizontalLayout {
                        padding-left: 14px; spacing: 12px; alignment: start;
                        Image { source: @image-url("icons/next.svg"); width: 16px; height: 16px; colorize: #b0b0b0; vertical-alignment: center; }
                        Text { text: "Play next"; font-size: 14px; font-weight: 500; color: #e0e0e0; vertical-alignment: center; }
                    }
                    rctx-pn := TouchArea { clicked => { root.play-next-clicked(); row-ctx-popup.close(); } }
                }
                Rectangle {
                    height: 38px; border-radius: 4px;
                    background: rctx2.has-hover ? #ffffff14 : transparent;
                    HorizontalLayout {
                        padding-left: 14px; spacing: 12px; alignment: start;
                        Image { source: @image-url("icons/play.svg"); width: 16px; height: 16px; colorize: #b0b0b0; vertical-alignment: center; }
                        Text { text: "Play"; font-size: 14px; font-weight: 500; color: #e0e0e0; vertical-alignment: center; }
                    }
                    rctx2 := TouchArea { clicked => { root.play-clicked(); row-ctx-popup.close(); } }
                }
                Rectangle {
                    height: 38px; border-radius: 4px;
                    background: rctx-radio.has-hover ? #ffffff14 : transparent;
                    HorizontalLayout {
                        padding-left: 14px; spacing: 12px; alignment: start;
                        Image { source: @image-url("icons/radio.svg"); width: 16px; height: 16px; colorize: #b0b0b0; vertical-alignment: center; }
                        Text { text: "Go to song radio"; font-size: 14px; font-weight: 500; color: #e0e0e0; vertical-alignment: center; }
                    }
                    rctx-radio := TouchArea { clicked => { root.song-radio-clicked(); row-ctx-popup.close(); } }
                }
                Rectangle {
                    height: 38px; border-radius: 4px;
                    background: rctx-artist.has-hover ? #ffffff14 : transparent;
                    HorizontalLayout {
                        padding-left: 14px; spacing: 12px; alignment: start;
                        Text { text: "👤"; font-size: 14px; color: #b0b0b0; vertical-alignment: center; width: 20px; }
                        Text { text: "Go to artist"; font-size: 14px; font-weight: 500; color: #e0e0e0; vertical-alignment: center; }
                    }
                    rctx-artist := TouchArea { clicked => { root.go-to-artist-clicked(); row-ctx-popup.close(); } }
                }
                Rectangle {
                    height: 38px; border-radius: 4px;
                    background: rctx-album.has-hover ? #ffffff14 : transparent;
                    HorizontalLayout {
                        padding-left: 14px; spacing: 12px; alignment: start;
                        Image { source: @image-url("icons/album.svg"); width: 16px; height: 16px; colorize: #b0b0b0; vertical-alignment: center; }
                        Text { text: "Go to album"; font-size: 14px; font-weight: 500; color: #e0e0e0; vertical-alignment: center; }
                    }
                    rctx-album := TouchArea { clicked => { root.go-to-album-clicked(); row-ctx-popup.close(); } }
                }
                if root.show-unlike: Rectangle {
                    height: 38px; border-radius: 4px;
                    background: rctx-unlike.has-hover ? #ffffff14 : transparent;
                    HorizontalLayout {
                        padding-left: 14px; spacing: 12px; alignment: start;
                        Text { text: "\u{2764}"; font-size: 14px; color: #e85d5d; vertical-alignment: center; width: 20px; }
                        Text { text: "Remove from liked"; font-size: 14px; font-weight: 500; color: #e0e0e0; vertical-alignment: center; }
                    }
                    rctx-unlike := TouchArea { clicked => { root.unlike-clicked(); row-ctx-popup.close(); } }
                }
                Rectangle {
                    height: 1px; background: #ffffff10;
                }
                Rectangle {
                    height: 38px; border-radius: 4px;
                    background: rctx-dislike.has-hover ? #ffffff14 : transparent;
                    HorizontalLayout {
                        padding-left: 14px; spacing: 12px; alignment: start;
                        Text { text: "\u{1F6AB}"; font-size: 13px; color: #b0b0b0; vertical-alignment: center; width: 20px; }
                        Text { text: "Remove from taste profile"; font-size: 13px; font-weight: 500; color: #e0e0e0; vertical-alignment: center; }
                    }
                    rctx-dislike := TouchArea { clicked => { root.dislike-clicked(); row-ctx-popup.close(); } }
                }
            }
        }
    }
}

component GenreTile inherits Rectangle {
    in property <string> label; in property <color> tile-color; in property <string> icon;
    callback clicked();
    height: 100px; border-radius: 12px;
    background: ta.has-hover ? tile-color.brighter(0.1) : tile-color;
    animate background { duration: 120ms; }
    HorizontalLayout {
        padding: 20px; spacing: 12px; alignment: start;
        Text { text: root.icon; font-size: 26px; vertical-alignment: center; }
        Text { text: root.label; font-size: 16px; font-weight: 600; color: #ffffff; vertical-alignment: center; }
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

component SongCard inherits Rectangle {
    in property <string> card-title;
    in property <string> card-artist;
    in property <string> avatar-letter;
    in property <bool> is-now-playing: false;
    in property <bool> is-playing: false;
    in property <image> thumbnail;
    in property <bool> has-thumbnail: false;
    in property <string> video-id: "";
    callback clicked();
    callback queue-clicked();
    callback play-next-clicked();
    callback pause-clicked();
    callback song-radio-clicked();
    callback go-to-artist-clicked();
    width: 200px; height: 260px; border-radius: 8px;
    background: ta.has-hover ? #1a1a1a : #121212;
    animate background { duration: 120ms; }

    VerticalLayout {
        padding: 12px; spacing: 12px;
        // Square thumbnail with play button overlay
        Rectangle {
            width: 176px; height: 176px; border-radius: 8px; clip: true;
            background: #1a1a1a;
            if has-thumbnail: Image {
                source: thumbnail; width: parent.width; height: parent.height; image-fit: cover;
            }
            if !has-thumbnail: Rectangle {
                width: parent.width; height: parent.height;
                background: is-now-playing
                    ? @linear-gradient(135deg, #2a0a0a 0%, #1a0808 100%)
                    : @linear-gradient(135deg, #1a1a2a 0%, #0f0f18 100%);
                Text {
                    text: is-now-playing ? "▶" : (avatar-letter == "" ? "♪" : avatar-letter);
                    color: is-now-playing ? #e85d5d : #4a4a5a;
                    font-size: 36px; font-weight: 700;
                    horizontal-alignment: center; vertical-alignment: center;
                }
            }
            // Play/Pause button on hover (Spotify-style, bottom-right)
            if ta.has-hover || is-now-playing: Rectangle {
                x: parent.width - 52px; y: parent.height - 52px;
                width: 44px; height: 44px; border-radius: 22px;
                background: play-ta.has-hover ? #1ed760 : #1db954;
                drop-shadow-blur: 8px; drop-shadow-color: #00000080; drop-shadow-offset-y: 4px;
                if !(is-now-playing && is-playing): Image { source: @image-url("icons/play.svg"); width: 20px; height: 20px; colorize: #000000; x: 13px; y: 12px; }
                if is-now-playing && is-playing: Image { source: @image-url("icons/pause.svg"); width: 20px; height: 20px; colorize: #000000; x: 12px; y: 12px; }
                play-ta := TouchArea {
                    clicked => {
                        if (root.is-now-playing && root.is-playing) {
                            root.pause-clicked();
                        } else {
                            root.clicked();
                        }
                    }
                }
            }
            // Now playing indicator bar
            if is-now-playing: Rectangle {
                x: 0; y: parent.height - 3px; width: parent.width; height: 3px;
                background: #1db954;
            }
        }
        VerticalLayout {
            spacing: 4px; padding-left: 2px;
            Text { text: card-title; font-size: 14px; font-weight: 700; color: #e0e0e0; overflow: elide; }
            Text { text: card-artist; font-size: 12px; font-weight: 500; color: #7a7a7a; overflow: elide; }
        }
    }
    ta := TouchArea {
        clicked => { root.clicked(); }
        pointer-event(e) => {
            if e.button == PointerEventButton.right && e.kind == PointerEventKind.up {
                ctx-popup.show();
            }
        }
    }

    // Context menu popup (auto-dismisses on click outside)
    ctx-popup := PopupWindow {
        x: 40px; y: 100px;
        width: 200px;
        Rectangle {
            width: 200px; height: 220px;
            border-radius: 8px; background: #282828;
            drop-shadow-blur: 16px; drop-shadow-color: #00000080; drop-shadow-offset-y: 4px;
            VerticalLayout {
                padding: 6px;
                Rectangle {
                    height: 40px; border-radius: 4px;
                    background: ctx1.has-hover ? #ffffff14 : transparent;
                    HorizontalLayout {
                        padding-left: 14px; spacing: 12px; alignment: start;
                        Text { text: "+"; font-size: 18px; color: #b0b0b0; vertical-alignment: center; width: 20px; }
                        Text { text: "Add to queue"; font-size: 14px; font-weight: 500; color: #e0e0e0; vertical-alignment: center; }
                    }
                    ctx1 := TouchArea { clicked => { root.queue-clicked(); ctx-popup.close(); } }
                }
                Rectangle {
                    height: 40px; border-radius: 4px;
                    background: ctx-pn.has-hover ? #ffffff14 : transparent;
                    HorizontalLayout {
                        padding-left: 14px; spacing: 12px; alignment: start;
                        Image { source: @image-url("icons/next.svg"); width: 16px; height: 16px; colorize: #b0b0b0; vertical-alignment: center; }
                        Text { text: "Play next"; font-size: 14px; font-weight: 500; color: #e0e0e0; vertical-alignment: center; }
                    }
                    ctx-pn := TouchArea { clicked => { root.play-next-clicked(); ctx-popup.close(); } }
                }
                Rectangle {
                    height: 40px; border-radius: 4px;
                    background: ctx2.has-hover ? #ffffff14 : transparent;
                    HorizontalLayout {
                        padding-left: 14px; spacing: 12px; alignment: start;
                        Text { text: "▶"; font-size: 14px; color: #b0b0b0; vertical-alignment: center; width: 20px; }
                        Text { text: "Play"; font-size: 14px; font-weight: 500; color: #e0e0e0; vertical-alignment: center; }
                    }
                    ctx2 := TouchArea { clicked => { root.clicked(); ctx-popup.close(); } }
                }
                Rectangle {
                    height: 40px; border-radius: 4px;
                    background: ctx3.has-hover ? #ffffff14 : transparent;
                    HorizontalLayout {
                        padding-left: 14px; spacing: 12px; alignment: start;
                        Image { source: @image-url("icons/radio.svg"); width: 16px; height: 16px; colorize: #b0b0b0; vertical-alignment: center; }
                        Text { text: "Go to song radio"; font-size: 14px; font-weight: 500; color: #e0e0e0; vertical-alignment: center; }
                    }
                    ctx3 := TouchArea { clicked => { root.song-radio-clicked(); ctx-popup.close(); } }
                }
                Rectangle {
                    height: 40px; border-radius: 4px;
                    background: ctx4.has-hover ? #ffffff14 : transparent;
                    HorizontalLayout {
                        padding-left: 14px; spacing: 12px; alignment: start;
                        Text { text: "👤"; font-size: 14px; color: #b0b0b0; vertical-alignment: center; width: 20px; }
                        Text { text: "Go to artist"; font-size: 14px; font-weight: 500; color: #e0e0e0; vertical-alignment: center; }
                    }
                    ctx4 := TouchArea { clicked => { root.go-to-artist-clicked(); ctx-popup.close(); } }
                }
            }
        }
    }
}

// ─── Main window ──────────────────────────────────────────────────────────────

export component NativeShellWindow inherits Window {
    // Playback state
    in-out property <string> track-title: "Nothing playing";
    in-out property <string> track-artist: "Select a song to start";
    in-out property <bool> is-playing: false;
    in-out property <float> progress: 0.0;
    in-out property <string> current-time: "0:00";
    in-out property <string> total-time: "--:--";
    in-out property <float> volume: 0.8;
    in-out property <string> track-initial: "?";
    in-out property <image> album-art;
    in-out property <bool> has-album-art: false;
    in-out property <bool> is-liked: false;
    in-out property <string> now-playing-video-id: "";

    // Navigation
    in-out property <string> current-view: "Home";
    in-out property <bool> sidebar-open: true;
    in-out property <bool> queue-pane-open: false;
    in-out property <string> library-tab: "Liked";
    in-out property <[AlbumItem]> library-albums: [];
    in-out property <[ArtistItem]> library-artists: [];
    in-out property <[PlaylistItem]> library-playlists: [];
    in-out property <string> library-sort: "recent";
    callback load-library-data();
    callback sort-library(string);
    callback navigate-to-playlist(string);

    // Data
    in-out property <[SongItem]> search-results: [];
    in-out property <[SongItem]> queue: [];
    in-out property <[SongItem]> liked-songs: [];
    in-out property <bool> autoplay-enabled: true;
    in-out property <[SongItem]> autoplay-queue: [];
    callback set-autoplay-enabled(bool);
    callback play-autoplay-song(int);
    in-out property <[SongItem]> trending-songs: [];
    in-out property <[SongItem]> personalized-songs: [];

    // Home screen enhancements
    in-out property <[AlbumItem]> home-new-releases: [];
    in-out property <[SongItem]> home-mix-1: [];
    in-out property <[SongItem]> home-mix-2: [];
    in-out property <[SongItem]> home-mix-3: [];
    in-out property <string> home-mix-1-title: "Your Mix";
    in-out property <string> home-mix-2-title: "Discover Mix";
    in-out property <string> home-mix-3-title: "Chill Mix";
    in-out property <[SongItem]> home-genre-mix: [];
    in-out property <string> home-genre-mix-title: "";
    in-out property <[SongItem]> home-language-section: [];
    in-out property <string> home-language-title: "";
    callback load-home-data();
    callback play-mix(int);

    // Artist view
    in-out property <string> artist-view-name: "";
    in-out property <[SongItem]> artist-view-songs: [];
    in-out property <[AlbumItem]> artist-view-albums: [];
    in-out property <image> artist-view-thumbnail;
    in-out property <bool> artist-view-has-thumbnail: false;
    in-out property <string> artist-view-description: "";
    in-out property <bool> artist-view-subscribed: false;
    callback toggle-subscribe-artist();
    in-out property <[AlbumItem]> artist-view-singles: [];
    in-out property <[ArtistItem]> artist-view-related: [];
    in-out property <[SongItem]> artist-view-videos: [];
    in-out property <AlbumItem> artist-view-latest-release: { title: "", browse-id: "", artist: "", year: "", has-thumbnail: false };
    in-out property <bool> artist-view-has-latest: false;

    // Radio view
    in-out property <string> radio-title: "";
    in-out property <[SongItem]> radio-songs: [];
    callback play-radio();
    callback play-album();

    // Playlist view
    in-out property <string> playlist-view-title: "";
    in-out property <[SongItem]> playlist-view-songs: [];
    in-out property <image> playlist-view-thumbnail;
    in-out property <bool> playlist-view-has-thumbnail: false;
    in-out property <string> playlist-view-count: "";
    in-out property <string> playlist-view-duration: "";
    in-out property <[PlaylistItem]> playlist-view-similar: [];
    in-out property <bool> playlist-view-liked: false;
    callback play-playlist();
    callback toggle-like-playlist();

    // Album view
    in-out property <string> album-view-title: "";
    in-out property <string> album-view-artist: "";
    in-out property <string> album-view-year: "";
    in-out property <[SongItem]> album-view-songs: [];
    in-out property <image> album-view-thumbnail;
    in-out property <bool> album-view-has-thumbnail: false;
    in-out property <string> album-view-duration: "";
    in-out property <string> album-view-description: "";
    in-out property <[AlbumItem]> album-view-more-by-artist: [];
    in-out property <[AlbumItem]> album-view-similar: [];
    in-out property <bool> album-view-liked: false;
    callback toggle-like-album();

    // Search enhancements
    in-out property <string> search-filter: "All";
    in-out property <[ArtistItem]> search-artists: [];
    in-out property <[AlbumItem]> search-albums: [];

    in-out property <bool> is-loading: false;

    // Callbacks
    callback toggle-play-pause();
    callback prev-track();
    callback next-track();
    callback seek(float);
    callback set-volume(float);
    callback do-search(string);
    callback live-search(string);
    in-out property <[SongItem]> search-suggestions: [];
    in-out property <bool> search-dropdown-open: false;
    callback play-song(string, string, string, int);
    callback queue-song(string, string, string);
    callback play-next-song(string, string, string, int);
    callback remove-from-queue(int);
    callback remove-from-autoplay(int);
    callback navigate(string);
    callback toggle-sidebar();
    callback toggle-queue-pane();
    callback like-current();
    callback unlike-song(string);
    callback dislike-song(string, string, string, int);
    callback clear-cache();
    callback explore-genre(string);
    in-out property <[MoodItem]> explore-moods: [];
    in-out property <[SongItem]> explore-new-releases: [];
    callback load-explore-data();
    callback explore-mood(string);
    callback navigate-to-artist(string);
    callback navigate-to-album(string);
    callback start-song-radio(string);
    callback go-to-song-artist(string);
    callback go-to-song-album(string);
    callback nav-back();
    callback nav-forward();
    callback set-minimize-to-tray(bool);
    in-out property <bool> can-go-back: false;
    in-out property <bool> can-go-forward: false;
    in-out property <bool> minimize-to-tray: true;
    // Cache
    in-out property <int> cache-limit-mb: 500;
    in-out property <int> cache-used-mb: 0;
    in-out property <int> cache-song-count: 0;
    callback set-cache-limit(int);

    // Essential add-ons (yt-dlp / ffmpeg) — optional third-party tools, not bundled.
    in-out property <bool> ytdlp-installed: false;
    in-out property <bool> ffmpeg-installed: false;
    in-out property <bool> addon-busy: false;
    in-out property <string> addon-status: "";
    in-out property <string> addon-installing: "";   // "ytdlp" | "ffmpeg" | ""
    in-out property <float> addon-progress: 0.0;      // 0.0–1.0, negative = indeterminate
    callback install-ytdlp();
    callback install-ffmpeg();
    callback refresh-addons();

    // First-run onboarding popup for add-on installation.
    in-out property <bool> show-onboarding: false;
    callback dismiss-onboarding();

    in-out property <string> window-title: "Auricle";
    title: window-title;
    icon: @image-url("../icons/icon.png");
    preferred-width: 1280px; preferred-height: 800px;
    min-width: 800px; min-height: 500px;
    background: #000000;
    default-font-family: "Segoe UI Variable";
    default-font-size: 14px;
    default-font-weight: 500;

    forward-focus: key-scope;
    key-scope := FocusScope {
        key-pressed(e) => {
            if e.text == " "           { toggle-play-pause(); return accept; }
            if e.text == Key.LeftArrow { prev-track();         return accept; }
            if e.text == Key.RightArrow{ next-track();         return accept; }
            if e.text == Key.Escape    {
                if queue-pane-open { toggle-queue-pane(); return accept; }
            }
            reject
        }

        VerticalLayout {

            // ── Main area (above player bar) ──────────────────────────────
            HorizontalLayout {
                vertical-stretch: 1;

                // ── Left sidebar ──────────────────────────────────────────
                if sidebar-open: Rectangle {
                    width: 260px; background: #0a0a0a;
                    Rectangle { x: parent.width - 1px; y: 0; width: 1px; height: parent.height; background: #1a1a1a; }

                    VerticalLayout {
                        padding-left: 18px; padding-right: 18px;
                        padding-top: 20px; padding-bottom: 16px;

                        // Logo
                        HorizontalLayout {
                            height: 44px; spacing: 10px; alignment: start;
                            Text { text: "▶"; color: #e85d5d; font-size: 22px; vertical-alignment: center; }
                            Text { text: "Auricle"; color: #ffffff; font-size: 18px; font-weight: 700; vertical-alignment: center; }
                        }

                        Rectangle { height: 20px; }

                        // Navigation
                        NavBtn { label: "Home";     nav-icon: @image-url("icons/home.svg"); active: current-view == "Home";     clicked => { navigate("Home"); }     }
                        NavBtn { label: "Explore";  nav-icon: @image-url("icons/explore.svg"); active: current-view == "Explore";  clicked => { navigate("Explore"); }  }
                        NavBtn { label: "Library";  nav-icon: @image-url("icons/library.svg"); active: current-view == "Library";  clicked => { navigate("Library"); }  }
                        NavBtn { label: "Settings"; nav-icon: @image-url("icons/settings.svg"); active: current-view == "Settings"; clicked => { navigate("Settings"); } }

                        Rectangle { height: 24px; }
                        Rectangle { height: 1px; background: #1a1a1a; }
                        Rectangle { height: 20px; }

                        // Liked Songs shortcut
                        Rectangle {
                            height: 56px; border-radius: 8px;
                            background: ls-ta.has-hover ? #ffffff0c : #ffffff06;
                            HorizontalLayout {
                                padding-left: 12px; padding-right: 12px; padding-top: 10px; padding-bottom: 10px; spacing: 12px; alignment: start;
                                Rectangle {
                                    width: 36px; height: 36px; border-radius: 4px;
                                    background: @linear-gradient(135deg, #4a18a8 0%, #1a8a5a 100%);
                                    Text { text: "♥"; color: #ffffff; font-size: 16px; horizontal-alignment: center; vertical-alignment: center; }
                                }
                                VerticalLayout {
                                    alignment: center; spacing: 2px; horizontal-stretch: 1;
                                    Text { text: "Liked Songs"; font-size: 13px; font-weight: 600; color: #e0e0e0; }
                                    Text { text: "\{liked-songs.length} songs"; font-size: 11px; color: #5a5a5a; }
                                }
                            }
                            ls-ta := TouchArea { clicked => { library-tab = "Liked"; navigate("Library"); } }
                        }



                        Rectangle { vertical-stretch: 1; }
                    }
                }

                // ── Center content area ───────────────────────────────────
                VerticalLayout {
                    horizontal-stretch: 1;

                    // Header bar
                    Rectangle {
                        height: 60px; background: #000000;
                        Rectangle { y: parent.height - 1px; height: 1px; width: parent.width; background: #1a1a1a; }
                        HorizontalLayout {
                            padding-left: 20px; padding-right: 20px; spacing: 12px; alignment: center;

                            IconBtn { svg-icon: @image-url("icons/menu.svg"); use-svg: true; icon-color: #808080; clicked => { toggle-sidebar(); } }

                            // Back / Forward
                            Rectangle {
                                width: 36px; height: 36px; border-radius: 18px;
                                background: can-go-back && nav-back-ta.has-hover ? #ffffff14 : transparent;
                                Text { text: "←"; font-size: 18px; color: can-go-back ? #ffffff : #3a3a3a; horizontal-alignment: center; vertical-alignment: center; }
                                nav-back-ta := TouchArea { enabled: can-go-back; clicked => { nav-back(); } }
                            }
                            Rectangle {
                                width: 36px; height: 36px; border-radius: 18px;
                                background: can-go-forward && nav-fwd-ta.has-hover ? #ffffff14 : transparent;
                                Text { text: "→"; font-size: 18px; color: can-go-forward ? #ffffff : #3a3a3a; horizontal-alignment: center; vertical-alignment: center; }
                                nav-fwd-ta := TouchArea { enabled: can-go-forward; clicked => { nav-forward(); } }
                            }

                            // Search bar
                            search-bar-rect := Rectangle {
                                width: 420px; height: 40px; border-radius: 20px;
                                background: #1a1a1a;
                                border-color: search-inp.has-focus ? #ffffff30 : #ffffff10;
                                border-width: 1px;
                                HorizontalLayout {
                                    padding-left: 14px; padding-right: 40px; padding-top: 10px; padding-bottom: 10px; spacing: 10px; alignment: start;
                                    Image { source: @image-url("icons/search.svg"); width: 18px; height: 18px; colorize: search-inp.has-focus ? #ffffff : #5a5a5a; vertical-alignment: center; }
                                    search-inp := TextInput {
                                        horizontal-stretch: 1;
                                        font-size: 14px; color: #e0e0e0;
                                        vertical-alignment: center;
                                        accepted => { do-search(self.text); search-dropdown-open = false; }
                                        edited => { live-search(self.text); search-dropdown-open = true; }
                                    }
                                    if search-inp.text == "": Text {
                                        text: "Search songs, albums, artists...";
                                        font-size: 14px; color: #4a4a4a;
                                        vertical-alignment: center;
                                    }
                                }
                                // Background click area to focus search (below the X button)
                                TouchArea { x: 0; y: 0; width: parent.width; height: parent.height; clicked => { search-inp.focus(); } }
                                // Clear button (X) - absolutely positioned at right edge
                                if search-inp.text != "": Rectangle {
                                    x: parent.width - 36px; y: 5px;
                                    width: 30px; height: 30px; border-radius: 15px;
                                    background: clr-btn.has-hover ? #ffffff14 : transparent;
                                    Image { source: @image-url("icons/close.svg"); width: 14px; height: 14px; colorize: #b0b0b0; x: 8px; y: 8px; }
                                    clr-btn := TouchArea { clicked => { search-inp.text = ""; search-inp.focus(); live-search(""); } }
                                }
                            }

                            // Nav pills
                            HorizontalLayout {
                                spacing: 4px; width: 220px;
                                TabPill { label: "Home";    active: current-view == "Home";    clicked => { navigate("Home"); }    }
                                TabPill { label: "Explore"; active: current-view == "Explore"; clicked => { navigate("Explore"); } }
                                TabPill { label: "Library"; active: current-view == "Library"; clicked => { navigate("Library"); } }
                            }
                        }

                    }

                    // View area
                    Rectangle {
                        vertical-stretch: 1; background: #000000; clip: true;

                        // Loading
                        if is-loading: VerticalLayout {
                            alignment: center; spacing: 10px;
                            Text { text: "Searching..."; font-size: 18px; color: #808080; horizontal-alignment: center; }
                            Text { text: "Hold tight"; font-size: 13px; color: #4a4a4a; horizontal-alignment: center; }
                        }

                        // HOME
                        if !is-loading && current-view == "Home": Flickable {
                            viewport-height: home-col.preferred-height + 60px;
                            home-col := VerticalLayout {
                                padding: 32px; padding-top: 28px; spacing: 0px;

                                // ── Hero banner (Apple Music style) ──────────────────────────
                                Rectangle {
                                    height: 140px; border-radius: 14px;
                                    background: @linear-gradient(135deg, #2a1525 0%, #1a1a3a 50%, #152530 100%);
                                    border-color: #ffffff10; border-width: 1px;

                                    HorizontalLayout {
                                        padding-left: 32px; padding-right: 28px; alignment: start;
                                        VerticalLayout {
                                            alignment: center; spacing: 8px;
                                            Text { text: "Good listening"; font-size: 32px; font-weight: 800; color: #ffffff; }
                                            Text {
                                                text: now-playing-video-id != ""
                                                    ? "▶  " + track-title + "  •  " + track-artist
                                                    : (queue.length > 0 ? "\{queue.length} songs in queue" : "Search or explore to get started");
                                                font-size: 13px; color: now-playing-video-id != "" ? #e85d5d : #8a8a8a;
                                                font-weight: now-playing-video-id != "" ? 500 : 400;
                                            }
                                        }
                                    }
                                }



                                // ── Trending Now ─────────────────────────────────────────────
                                if trending-songs.length > 0: VerticalLayout {
                                    padding-top: 44px; spacing: 16px;
                                    HorizontalLayout {
                                        height: 28px; alignment: space-between;
                                        Text { text: "Trending Now"; font-size: 22px; font-weight: 700; color: #ffffff; vertical-alignment: center; }
                                        Text { text: "🔥"; font-size: 18px; vertical-alignment: center; }
                                    }
                                    Rectangle {
                                        height: 270px; clip: true;
                                        Flickable {
                                            width: parent.width; height: parent.height;
                                            viewport-width: trend-row.preferred-width + 16px;
                                            trend-row := HorizontalLayout {
                                                spacing: 16px;
                                                for item[i] in trending-songs: SongCard {
                                                    card-title: item.title; card-artist: item.artist;
                                                    avatar-letter: item.avatar-letter;
                                                    thumbnail: item.thumbnail; has-thumbnail: item.has-thumbnail;
                                                    is-now-playing: item.video-id == now-playing-video-id;
                                                    is-playing: root.is-playing && item.video-id == now-playing-video-id;
                                                    video-id: item.video-id;
                                                    clicked => { play-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                                    queue-clicked => { queue-song(item.video-id, item.title, item.artist); }
                                                    play-next-clicked => { play-next-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                                    pause-clicked => { toggle-play-pause(); }
                                                    song-radio-clicked => { start-song-radio(item.video-id); }
                                                    go-to-artist-clicked => { go-to-song-artist(item.artist); }
                                                }
                                            }
                                        }
                                    }
                                }

                                // ── Based on your listening ──────────────────────────────────
                                if personalized-songs.length > 0: VerticalLayout {
                                    padding-top: 44px; spacing: 16px;
                                    HorizontalLayout {
                                        height: 28px; alignment: space-between;
                                        Text { text: "Based on your listening"; font-size: 22px; font-weight: 700; color: #ffffff; vertical-alignment: center; }
                                        Text { text: "✨"; font-size: 18px; vertical-alignment: center; }
                                    }
                                    Rectangle {
                                        height: 270px; clip: true;
                                        Flickable {
                                            width: parent.width; height: parent.height;
                                            viewport-width: pers-row.preferred-width + 16px;
                                            pers-row := HorizontalLayout {
                                                spacing: 16px;
                                                for item[i] in personalized-songs: SongCard {
                                                    card-title: item.title; card-artist: item.artist;
                                                    avatar-letter: item.avatar-letter;
                                                    thumbnail: item.thumbnail; has-thumbnail: item.has-thumbnail;
                                                    is-now-playing: item.video-id == now-playing-video-id;
                                                    is-playing: root.is-playing && item.video-id == now-playing-video-id;
                                                    video-id: item.video-id;
                                                    clicked => { play-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                                    queue-clicked => { queue-song(item.video-id, item.title, item.artist); }
                                                    play-next-clicked => { play-next-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                                    pause-clicked => { toggle-play-pause(); }
                                                    song-radio-clicked => { start-song-radio(item.video-id); }
                                                    go-to-artist-clicked => { go-to-song-artist(item.artist); }
                                                }
                                            }
                                        }
                                    }
                                }

                                // ── New releases for you ─────────────────────────────────────
                                if home-new-releases.length > 0: VerticalLayout {
                                    padding-top: 44px; spacing: 16px;
                                    HorizontalLayout {
                                        height: 28px; alignment: space-between;
                                        Text { text: "New releases for you"; font-size: 22px; font-weight: 700; color: #ffffff; vertical-alignment: center; }
                                        Text { text: "💿"; font-size: 18px; vertical-alignment: center; }
                                    }
                                    Rectangle {
                                        height: 230px; clip: true;
                                        Flickable {
                                            width: parent.width; height: parent.height;
                                            viewport-width: nr-row.preferred-width + 16px;
                                            nr-row := HorizontalLayout {
                                                spacing: 16px;
                                                for alb[i] in home-new-releases: Rectangle {
                                                    width: 176px; height: 220px; border-radius: 8px;
                                                    background: nr-ta.has-hover ? #1a1a1a : #121212;
                                                    animate background { duration: 120ms; }
                                                    VerticalLayout {
                                                        padding: 8px; spacing: 8px;
                                                        Rectangle {
                                                            width: 160px; height: 160px; border-radius: 8px; clip: true;
                                                            background: #1a1a1a;
                                                            if alb.has-thumbnail: Image {
                                                                source: alb.thumbnail; width: parent.width; height: parent.height; image-fit: cover;
                                                            }
                                                            if !alb.has-thumbnail: Text {
                                                                text: "💿"; font-size: 40px;
                                                                horizontal-alignment: center; vertical-alignment: center;
                                                            }
                                                        }
                                                        VerticalLayout {
                                                            spacing: 2px; padding-left: 4px;
                                                            Text { text: alb.title; font-size: 13px; font-weight: 600; color: #e0e0e0; overflow: elide; }
                                                            Text { text: alb.artist + (alb.year != "" ? "  •  " + alb.year : ""); font-size: 12px; color: #6a6a6a; overflow: elide; }
                                                        }
                                                    }
                                                    nr-ta := TouchArea { clicked => { navigate-to-album(alb.browse-id); } }
                                                }
                                            }
                                        }
                                    }
                                }

                                // ── Mixed for you ────────────────────────────────────────────
                                if home-mix-1.length > 0: VerticalLayout {
                                    padding-top: 44px; spacing: 16px;
                                    HorizontalLayout {
                                        height: 28px; alignment: space-between;
                                        Text { text: "Mixed for you"; font-size: 22px; font-weight: 700; color: #ffffff; vertical-alignment: center; }
                                        Text { text: "🎧"; font-size: 18px; vertical-alignment: center; }
                                    }
                                    Rectangle {
                                        height: 170px; clip: true;
                                        Flickable {
                                            width: parent.width; height: parent.height;
                                            viewport-width: mix-row.preferred-width + 16px;
                                            mix-row := HorizontalLayout {
                                                spacing: 16px;
                                                // Mix 1
                                                Rectangle {
                                                    width: 250px; height: 160px; border-radius: 12px;
                                                    background: mix1-ta.has-hover
                                                        ? @linear-gradient(135deg, #5a2d82 0%, #2a1545 100%)
                                                        : @linear-gradient(135deg, #4a1d72 0%, #1a0535 100%);
                                                    animate background { duration: 150ms; }
                                                    VerticalLayout {
                                                        padding: 20px; spacing: 8px; alignment: space-between;
                                                        VerticalLayout {
                                                            spacing: 4px;
                                                            Text { text: home-mix-1-title; font-size: 18px; font-weight: 700; color: #ffffff; }
                                                            Text { text: "\{home-mix-1.length} songs"; font-size: 12px; color: #b0b0b0; }
                                                        }
                                                        Rectangle {
                                                            width: 40px; height: 40px; border-radius: 20px;
                                                            background: #1db954;
                                                            Image { source: @image-url("icons/play.svg"); width: 18px; height: 18px; colorize: #000000; x: 12px; y: 11px; }
                                                        }
                                                    }
                                                    mix1-ta := TouchArea { clicked => { play-mix(1); } }
                                                }
                                                // Mix 2
                                                Rectangle {
                                                    width: 250px; height: 160px; border-radius: 12px;
                                                    background: mix2-ta.has-hover
                                                        ? @linear-gradient(135deg, #1a5a5a 0%, #0a2a2a 100%)
                                                        : @linear-gradient(135deg, #0a4a4a 0%, #001a1a 100%);
                                                    animate background { duration: 150ms; }
                                                    VerticalLayout {
                                                        padding: 20px; spacing: 8px; alignment: space-between;
                                                        VerticalLayout {
                                                            spacing: 4px;
                                                            Text { text: home-mix-2-title; font-size: 18px; font-weight: 700; color: #ffffff; }
                                                            Text { text: "\{home-mix-2.length} songs"; font-size: 12px; color: #b0b0b0; }
                                                        }
                                                        Rectangle {
                                                            width: 40px; height: 40px; border-radius: 20px;
                                                            background: #1db954;
                                                            Image { source: @image-url("icons/play.svg"); width: 18px; height: 18px; colorize: #000000; x: 12px; y: 11px; }
                                                        }
                                                    }
                                                    mix2-ta := TouchArea { clicked => { play-mix(2); } }
                                                }
                                                // Mix 3
                                                Rectangle {
                                                    width: 250px; height: 160px; border-radius: 12px;
                                                    background: mix3-ta.has-hover
                                                        ? @linear-gradient(135deg, #5a3a1a 0%, #2a1a0a 100%)
                                                        : @linear-gradient(135deg, #4a2a0a 0%, #1a0a00 100%);
                                                    animate background { duration: 150ms; }
                                                    VerticalLayout {
                                                        padding: 20px; spacing: 8px; alignment: space-between;
                                                        VerticalLayout {
                                                            spacing: 4px;
                                                            Text { text: home-mix-3-title; font-size: 18px; font-weight: 700; color: #ffffff; }
                                                            Text { text: "\{home-mix-3.length} songs"; font-size: 12px; color: #b0b0b0; }
                                                        }
                                                        Rectangle {
                                                            width: 40px; height: 40px; border-radius: 20px;
                                                            background: #1db954;
                                                            Image { source: @image-url("icons/play.svg"); width: 18px; height: 18px; colorize: #000000; x: 12px; y: 11px; }
                                                        }
                                                    }
                                                    mix3-ta := TouchArea { clicked => { play-mix(3); } }
                                                }
                                            }
                                        }
                                    }
                                }

                                // ── Genre Mix ────────────────────────────────────────────────
                                if home-genre-mix.length > 0: VerticalLayout {
                                    padding-top: 44px; spacing: 16px;
                                    HorizontalLayout {
                                        height: 28px; alignment: space-between;
                                        Text { text: home-genre-mix-title; font-size: 22px; font-weight: 700; color: #ffffff; vertical-alignment: center; }
                                        Text { text: "🎵"; font-size: 18px; vertical-alignment: center; }
                                    }
                                    Rectangle {
                                        height: 270px; clip: true;
                                        Flickable {
                                            width: parent.width; height: parent.height;
                                            viewport-width: genre-mix-row.preferred-width + 16px;
                                            genre-mix-row := HorizontalLayout {
                                                spacing: 16px;
                                                for item[i] in home-genre-mix: SongCard {
                                                    card-title: item.title; card-artist: item.artist;
                                                    avatar-letter: item.avatar-letter;
                                                    thumbnail: item.thumbnail; has-thumbnail: item.has-thumbnail;
                                                    is-now-playing: item.video-id == now-playing-video-id;
                                                    is-playing: root.is-playing && item.video-id == now-playing-video-id;
                                                    video-id: item.video-id;
                                                    clicked => { play-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                                    queue-clicked => { queue-song(item.video-id, item.title, item.artist); }
                                                    play-next-clicked => { play-next-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                                    pause-clicked => { toggle-play-pause(); }
                                                    song-radio-clicked => { start-song-radio(item.video-id); }
                                                    go-to-artist-clicked => { go-to-song-artist(item.artist); }
                                                }
                                            }
                                        }
                                    }
                                }

                                // ── Language-based music ─────────────────────────────────────
                                if home-language-section.length > 0: VerticalLayout {
                                    padding-top: 44px; spacing: 16px;
                                    HorizontalLayout {
                                        height: 28px; alignment: space-between;
                                        Text { text: home-language-title; font-size: 22px; font-weight: 700; color: #ffffff; vertical-alignment: center; }
                                        Text { text: "🌍"; font-size: 18px; vertical-alignment: center; }
                                    }
                                    Rectangle {
                                        height: 270px; clip: true;
                                        Flickable {
                                            width: parent.width; height: parent.height;
                                            viewport-width: lang-row.preferred-width + 16px;
                                            lang-row := HorizontalLayout {
                                                spacing: 16px;
                                                for item[i] in home-language-section: SongCard {
                                                    card-title: item.title; card-artist: item.artist;
                                                    avatar-letter: item.avatar-letter;
                                                    thumbnail: item.thumbnail; has-thumbnail: item.has-thumbnail;
                                                    is-now-playing: item.video-id == now-playing-video-id;
                                                    is-playing: root.is-playing && item.video-id == now-playing-video-id;
                                                    video-id: item.video-id;
                                                    clicked => { play-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                                    queue-clicked => { queue-song(item.video-id, item.title, item.artist); }
                                                    play-next-clicked => { play-next-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                                    pause-clicked => { toggle-play-pause(); }
                                                    song-radio-clicked => { start-song-radio(item.video-id); }
                                                    go-to-artist-clicked => { go-to-song-artist(item.artist); }
                                                }
                                            }
                                        }
                                    }
                                }

                                // ── Recently Liked ───────────────────────────────────────────
                                if liked-songs.length > 0: VerticalLayout {
                                    padding-top: 44px; spacing: 16px;
                                    HorizontalLayout {
                                        height: 28px; alignment: space-between;
                                        Text { text: "Recently Liked"; font-size: 22px; font-weight: 700; color: #ffffff; vertical-alignment: center; }
                                        rl-all := TouchArea {
                                            width: 60px; height: 24px;
                                            Text { text: "See all"; font-size: 12px; color: rl-all.has-hover ? #ffffff : #6a6a6a; vertical-alignment: center; horizontal-alignment: right; }
                                            clicked => { library-tab = "Liked"; navigate("Library"); }
                                        }
                                    }
                                    Rectangle {
                                        height: 270px; clip: true;
                                        Flickable {
                                            width: parent.width; height: parent.height;
                                            viewport-width: rl-row.preferred-width + 16px;
                                            rl-row := HorizontalLayout {
                                                spacing: 16px;
                                                for item[i] in liked-songs: SongCard {
                                                    card-title: item.title; card-artist: item.artist;
                                                    avatar-letter: item.avatar-letter;
                                                    thumbnail: item.thumbnail; has-thumbnail: item.has-thumbnail;
                                                    is-now-playing: item.video-id == now-playing-video-id;
                                                    is-playing: root.is-playing && item.video-id == now-playing-video-id;
                                                    video-id: item.video-id;
                                                    clicked => { play-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                                    queue-clicked => { queue-song(item.video-id, item.title, item.artist); }
                                                    play-next-clicked => { play-next-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                                    pause-clicked => { toggle-play-pause(); }
                                                    song-radio-clicked => { start-song-radio(item.video-id); }
                                                    go-to-artist-clicked => { go-to-song-artist(item.artist); }
                                                }
                                            }
                                        }
                                    }
                                }

                                // ── Empty state ──────────────────────────────────────────────
                                if queue.length == 0 && liked-songs.length == 0: Rectangle {
                                    height: 280px;
                                    VerticalLayout { alignment: center; spacing: 16px;
                                        Rectangle {
                                            width: 80px; height: 80px; border-radius: 40px;
                                            background: #0f0f0f;
                                            border-color: #1a1a1a; border-width: 1px;
                                            x: (parent.width - self.width) / 2;
                                            Text { text: "♪"; font-size: 36px; color: #3a3a3a; horizontal-alignment: center; vertical-alignment: center; }
                                        }
                                        Text { text: "Nothing playing yet"; font-size: 20px; font-weight: 600; color: #4a4a4a; horizontal-alignment: center; }
                                        Text { text: "Search above or explore to discover music"; font-size: 13px; color: #3a3a3a; horizontal-alignment: center; }
                                        Rectangle {
                                            height: 40px; width: 130px; border-radius: 20px; x: (parent.width - self.width) / 2;
                                            background: go-exp.has-hover ? #ffffff14 : #ffffff0a;
                                            animate background { duration: 100ms; }
                                            Text { text: "Explore →"; font-size: 13px; font-weight: 600; color: #b0b0b0; horizontal-alignment: center; vertical-alignment: center; }
                                            go-exp := TouchArea { clicked => { navigate("Explore"); } }
                                        }
                                    }
                                }
                            }
                        }

                        // SEARCH
                        if !is-loading && current-view == "Search": Flickable {
                            viewport-height: search-col.preferred-height + 40px;
                            search-col := VerticalLayout {
                                padding: 32px; padding-top: 24px; spacing: 0px;
                                // Filter tabs (Spotify-style)
                                HorizontalLayout {
                                    height: 40px; spacing: 8px; alignment: start;
                                    TabPill { label: "All";     active: search-filter == "All";     clicked => { search-filter = "All"; } }
                                    TabPill { label: "Songs";   active: search-filter == "Songs";   clicked => { search-filter = "Songs"; } }
                                    TabPill { label: "Albums";  active: search-filter == "Albums";  clicked => { search-filter = "Albums"; } }
                                    TabPill { label: "Artists"; active: search-filter == "Artists"; clicked => { search-filter = "Artists"; } }
                                }
                                Rectangle { height: 20px; }

                                // ── Artists results ──
                                if (search-filter == "All" || search-filter == "Artists") && search-artists.length > 0: VerticalLayout {
                                    spacing: 12px;
                                    Text { text: "Artists"; font-size: 18px; font-weight: 700; color: #ffffff; }
                                    Rectangle {
                                        height: 200px; clip: true;
                                        Flickable {
                                            width: parent.width; height: parent.height;
                                            viewport-width: artist-results-row.preferred-width + 16px;
                                            artist-results-row := HorizontalLayout {
                                                spacing: 16px;
                                                for art[i] in search-artists: Rectangle {
                                                    width: 160px; height: 190px; border-radius: 8px;
                                                    background: art-ta.has-hover ? #1a1a1a : #121212;
                                                    animate background { duration: 120ms; }
                                                    VerticalLayout {
                                                        padding: 12px; spacing: 10px; alignment: center;
                                                        Rectangle {
                                                            width: 120px; height: 120px; border-radius: 60px; clip: true;
                                                            background: #1a1a1a;
                                                            if art.has-thumbnail: Image {
                                                                source: art.thumbnail; width: parent.width; height: parent.height; image-fit: cover;
                                                            }
                                                            if !art.has-thumbnail: Text {
                                                                text: "♪"; color: #4a4a4a; font-size: 36px; font-weight: 700;
                                                                horizontal-alignment: center; vertical-alignment: center;
                                                            }
                                                        }
                                                        VerticalLayout {
                                                            spacing: 2px;
                                                            Text { text: art.name; font-size: 13px; font-weight: 600; color: #e0e0e0; overflow: elide; horizontal-alignment: center; }
                                                            Text { text: "Artist"; font-size: 11px; color: #6a6a6a; horizontal-alignment: center; }
                                                        }
                                                    }
                                                    art-ta := TouchArea { clicked => { navigate-to-artist(art.browse-id); } }
                                                }
                                            }
                                        }
                                    }
                                    Rectangle { height: 16px; }
                                }

                                // ── Albums results ──
                                if (search-filter == "All" || search-filter == "Albums") && search-albums.length > 0: VerticalLayout {
                                    spacing: 12px;
                                    Text { text: "Albums"; font-size: 18px; font-weight: 700; color: #ffffff; }
                                    Rectangle {
                                        height: 230px; clip: true;
                                        Flickable {
                                            width: parent.width; height: parent.height;
                                            viewport-width: album-results-row.preferred-width + 16px;
                                            album-results-row := HorizontalLayout {
                                                spacing: 16px;
                                                for alb[i] in search-albums: Rectangle {
                                                    width: 176px; height: 220px; border-radius: 8px;
                                                    background: alb-ta.has-hover ? #1a1a1a : #121212;
                                                    animate background { duration: 120ms; }
                                                    VerticalLayout {
                                                        padding: 8px; spacing: 8px;
                                                        Rectangle {
                                                            width: 160px; height: 160px; border-radius: 8px; clip: true;
                                                            background: #1a1a1a;
                                                            if alb.has-thumbnail: Image {
                                                                source: alb.thumbnail; width: parent.width; height: parent.height; image-fit: cover;
                                                            }
                                                            if !alb.has-thumbnail: Text {
                                                                text: "💿"; font-size: 40px;
                                                                horizontal-alignment: center; vertical-alignment: center;
                                                            }
                                                        }
                                                        VerticalLayout {
                                                            spacing: 2px; padding-left: 4px;
                                                            Text { text: alb.title; font-size: 13px; font-weight: 600; color: #e0e0e0; overflow: elide; }
                                                            Text { text: alb.artist; font-size: 12px; color: #6a6a6a; overflow: elide; }
                                                        }
                                                    }
                                                    alb-ta := TouchArea { clicked => { navigate-to-album(alb.browse-id); } }
                                                }
                                            }
                                        }
                                    }
                                    Rectangle { height: 16px; }
                                }

                                // ── Songs results ──
                                if (search-filter == "All" || search-filter == "Songs") && search-results.length > 0: VerticalLayout {
                                    spacing: 8px;
                                    if search-filter == "All": Rectangle {
                                        height: 100px; border-radius: 12px;
                                        background: #1a1a1a;
                                        HorizontalLayout {
                                            padding: 16px; spacing: 16px; alignment: start;
                                            Rectangle {
                                                width: 68px; height: 68px; border-radius: 8px; clip: true;
                                                background: #2a2a2a;
                                                if search-results[0].has-thumbnail: Image {
                                                    source: search-results[0].thumbnail; width: parent.width; height: parent.height; image-fit: cover;
                                                }
                                                if !search-results[0].has-thumbnail: Text {
                                                    text: search-results[0].avatar-letter; color: #6a6a6a; font-size: 24px; font-weight: 700;
                                                    horizontal-alignment: center; vertical-alignment: center;
                                                }
                                            }
                                            VerticalLayout {
                                                alignment: center; spacing: 4px; horizontal-stretch: 1;
                                                Text { text: search-results[0].title; font-size: 20px; font-weight: 700; color: #ffffff; overflow: elide; }
                                                Text { text: "Song • " + search-results[0].artist; font-size: 13px; color: #6a6a6a; }
                                            }
                                            Rectangle {
                                                width: 48px; height: 48px; border-radius: 24px;
                                                background: tr-play.has-hover ? #1ed760 : #1db954;
                                                Image { source: @image-url("icons/play.svg"); width: 20px; height: 20px; colorize: #000000; x: 15px; y: 14px; }
                                                tr-play := TouchArea { clicked => { play-song(search-results[0].video-id, search-results[0].title, search-results[0].artist, search-results[0].duration-secs); } }
                                            }
                                        }
                                    }
                                    Rectangle { height: 8px; }
                                    HorizontalLayout {
                                        height: 32px; alignment: start;
                                        Text { text: "Songs"; font-size: 18px; font-weight: 700; color: #ffffff; vertical-alignment: center; }
                                    }
                                    for item[i] in search-results: SongRow {
                                        song-title: item.title; song-artist: item.artist;
                                        song-album: item.album; song-duration: item.duration-str;
                                        idx-str: "\{i + 1}"; avatar-letter: item.avatar-letter;
                                        thumbnail: item.thumbnail; has-thumbnail: item.has-thumbnail;
                                        is-current: item.video-id == now-playing-video-id;
                                        play-clicked => { play-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                        queue-clicked => { queue-song(item.video-id, item.title, item.artist); }
                                        play-next-clicked => { play-next-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                        dislike-clicked => { dislike-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                        song-radio-clicked => { start-song-radio(item.video-id); }
                                        go-to-artist-clicked => { go-to-song-artist(item.artist); }
                                        go-to-album-clicked => { go-to-song-album(item.album); }
                                    }
                                }

                                // Empty state
                                if search-results.length == 0 && search-artists.length == 0 && search-albums.length == 0: Rectangle {
                                    height: 200px;
                                    VerticalLayout { alignment: center; spacing: 10px;
                                        Text { text: "No results yet"; font-size: 18px; color: #5a5a5a; horizontal-alignment: center; }
                                        Text { text: "Type a query and press Enter"; font-size: 13px; color: #3a3a3a; horizontal-alignment: center; }
                                    }
                                }
                            }
                        }

                        // ARTIST
                        if !is-loading && current-view == "Artist": Flickable {
                            viewport-height: artist-col.preferred-height + 60px;
                            artist-col := VerticalLayout {
                                spacing: 0px;
                                Rectangle {
                                    height: 280px;
                                    background: @linear-gradient(180deg, #4a0a0a 0%, #1a0505 60%, #000000 100%);
                                    clip: true;
                                    HorizontalLayout {
                                        padding: 32px; padding-top: 48px; spacing: 24px; alignment: start;
                                        Rectangle {
                                            width: 180px; height: 180px; border-radius: 90px; clip: true;
                                            background: #1a1a1a;
                                            if artist-view-has-thumbnail: Image {
                                                source: artist-view-thumbnail;
                                                width: parent.width; height: parent.height; image-fit: cover;
                                            }
                                            if !artist-view-has-thumbnail: Text {
                                                text: "♪"; color: #4a4a4a; font-size: 60px; font-weight: 700;
                                                horizontal-alignment: center; vertical-alignment: center;
                                            }
                                        }
                                        VerticalLayout {
                                            alignment: center; spacing: 8px;
                                            Text {
                                                text: artist-view-name;
                                                font-size: 40px; font-weight: 800; color: #ffffff;
                                                overflow: elide;
                                            }
                                            Text { text: "Artist"; font-size: 14px; color: #a0a0a0; font-weight: 500; }
                                            Rectangle { height: 12px; }
                                            HorizontalLayout {
                                                spacing: 12px; alignment: start;
                                                // Follow/Subscribe button
                                                Rectangle {
                                                    width: artist-view-subscribed ? 130px : 110px; height: 36px; border-radius: 18px;
                                                    background: artist-view-subscribed ? #ffffff14 : (artist-follow-ta.has-hover ? #ffffff20 : #ffffff14);
                                                    border-color: artist-view-subscribed ? #1db954 : #ffffff30; border-width: 1px;
                                                    HorizontalLayout {
                                                        alignment: center; spacing: 6px;
                                                        Image {
                                                            source: @image-url("icons/heart.svg");
                                                            width: 16px; height: 16px;
                                                            colorize: artist-view-subscribed ? #1db954 : #b0b0b0;
                                                            vertical-alignment: center;
                                                        }
                                                        Text {
                                                            text: artist-view-subscribed ? "Following" : "Follow";
                                                            font-size: 13px; font-weight: 600;
                                                            color: artist-view-subscribed ? #1db954 : #e0e0e0;
                                                            vertical-alignment: center;
                                                        }
                                                    }
                                                    artist-follow-ta := TouchArea { clicked => { toggle-subscribe-artist(); } }
                                                }
                                            }
                                        }
                                    }
                                }
                                // Latest Release highlight
                                if artist-view-has-latest: VerticalLayout {
                                    padding-left: 32px; padding-right: 32px; padding-top: 24px; spacing: 8px;
                                    Text { text: "Latest Release"; font-size: 22px; font-weight: 700; color: #ffffff; }
                                    Rectangle {
                                        height: 100px; border-radius: 12px;
                                        background: latest-ta.has-hover ? #2a1a1a : #1a1a1a;
                                        animate background { duration: 120ms; }
                                        HorizontalLayout {
                                            padding: 12px; spacing: 16px; alignment: start;
                                            Rectangle {
                                                width: 76px; height: 76px; border-radius: 8px; clip: true;
                                                background: #252525;
                                                if artist-view-latest-release.has-thumbnail: Image {
                                                    source: artist-view-latest-release.thumbnail;
                                                    width: parent.width; height: parent.height; image-fit: cover;
                                                }
                                                if !artist-view-latest-release.has-thumbnail: Text {
                                                    text: "💿"; font-size: 28px;
                                                    horizontal-alignment: center; vertical-alignment: center;
                                                }
                                            }
                                            VerticalLayout {
                                                alignment: center; spacing: 4px;
                                                HorizontalLayout {
                                                    spacing: 8px; alignment: start;
                                                    Rectangle {
                                                        width: 80px; height: 20px; border-radius: 4px;
                                                        background: #e53935;
                                                        Text {
                                                            text: "New Release"; font-size: 11px; font-weight: 700;
                                                            color: #ffffff; horizontal-alignment: center;
                                                            vertical-alignment: center;
                                                        }
                                                    }
                                                    Text {
                                                        text: artist-view-latest-release.year;
                                                        font-size: 12px; color: #8a8a8a;
                                                        vertical-alignment: center;
                                                    }
                                                }
                                                Text {
                                                    text: artist-view-latest-release.title;
                                                    font-size: 16px; font-weight: 600; color: #e0e0e0;
                                                    overflow: elide;
                                                }
                                                Text {
                                                    text: artist-view-latest-release.artist;
                                                    font-size: 13px; color: #7a7a7a;
                                                }
                                            }
                                        }
                                        latest-ta := TouchArea { clicked => { navigate-to-album(artist-view-latest-release.browse-id); } }
                                    }
                                }
                                VerticalLayout {
                                    padding-left: 32px; padding-right: 32px; padding-top: 32px; spacing: 8px;
                                    Text { text: "Popular"; font-size: 22px; font-weight: 700; color: #ffffff; }
                                    Rectangle { height: 8px; }
                                    for item[i] in artist-view-songs: SongRow {
                                        song-title: item.title; song-artist: item.artist;
                                        song-album: item.album; song-duration: item.duration-str;
                                        idx-str: "\{i + 1}"; avatar-letter: item.avatar-letter;
                                        thumbnail: item.thumbnail; has-thumbnail: item.has-thumbnail;
                                        is-current: item.video-id == now-playing-video-id;
                                        play-clicked => { play-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                        queue-clicked => { queue-song(item.video-id, item.title, item.artist); }
                                        play-next-clicked => { play-next-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                        dislike-clicked => { dislike-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                        song-radio-clicked => { start-song-radio(item.video-id); }
                                        go-to-artist-clicked => { go-to-song-artist(item.artist); }
                                        go-to-album-clicked => { go-to-song-album(item.album); }
                                    }
                                }
                                if artist-view-albums.length > 0: VerticalLayout {
                                    padding-left: 32px; padding-right: 32px; padding-top: 40px; spacing: 16px;
                                    Text { text: "Discography"; font-size: 22px; font-weight: 700; color: #ffffff; }
                                    Rectangle {
                                        height: 230px; clip: true;
                                        Flickable {
                                            width: parent.width; height: parent.height;
                                            viewport-width: disco-row.preferred-width + 16px;
                                            disco-row := HorizontalLayout {
                                                spacing: 16px;
                                                for album[i] in artist-view-albums: Rectangle {
                                                    width: 176px; height: 220px; border-radius: 8px;
                                                    background: album-card-ta.has-hover ? #1a1a1a : #121212;
                                                    animate background { duration: 120ms; }
                                                    VerticalLayout {
                                                        padding: 8px; spacing: 8px;
                                                        Rectangle {
                                                            width: 160px; height: 160px; border-radius: 8px; clip: true;
                                                            background: #1a1a1a;
                                                            if album.has-thumbnail: Image {
                                                                source: album.thumbnail;
                                                                width: parent.width; height: parent.height; image-fit: cover;
                                                            }
                                                            if !album.has-thumbnail: Text {
                                                                text: "💿"; font-size: 40px;
                                                                horizontal-alignment: center; vertical-alignment: center;
                                                            }
                                                        }
                                                        VerticalLayout {
                                                            spacing: 2px; padding-left: 4px;
                                                            Text { text: album.title; font-size: 13px; font-weight: 600; color: #e0e0e0; overflow: elide; }
                                                            Text { text: album.year; font-size: 12px; color: #6a6a6a; }
                                                        }
                                                    }
                                                    album-card-ta := TouchArea { clicked => { navigate-to-album(album.browse-id); } }
                                                }
                                            }
                                        }
                                    }
                                }
                                // Singles & EPs
                                if artist-view-singles.length > 0: VerticalLayout {
                                    padding-left: 32px; padding-right: 32px; padding-top: 40px; spacing: 16px;
                                    Text { text: "Singles & EPs"; font-size: 22px; font-weight: 700; color: #ffffff; }
                                    Rectangle {
                                        height: 230px; clip: true;
                                        Flickable {
                                            width: parent.width; height: parent.height;
                                            viewport-width: singles-row.preferred-width + 16px;
                                            singles-row := HorizontalLayout {
                                                spacing: 16px;
                                                for single[i] in artist-view-singles: Rectangle {
                                                    width: 176px; height: 220px; border-radius: 8px;
                                                    background: single-card-ta.has-hover ? #1a1a1a : #121212;
                                                    animate background { duration: 120ms; }
                                                    VerticalLayout {
                                                        padding: 8px; spacing: 8px;
                                                        Rectangle {
                                                            width: 160px; height: 160px; border-radius: 8px; clip: true;
                                                            background: #1a1a1a;
                                                            if single.has-thumbnail: Image {
                                                                source: single.thumbnail;
                                                                width: parent.width; height: parent.height; image-fit: cover;
                                                            }
                                                            if !single.has-thumbnail: Text {
                                                                text: "💿"; font-size: 40px;
                                                                horizontal-alignment: center; vertical-alignment: center;
                                                            }
                                                        }
                                                        VerticalLayout {
                                                            spacing: 2px; padding-left: 4px;
                                                            Text { text: single.title; font-size: 13px; font-weight: 600; color: #e0e0e0; overflow: elide; }
                                                            Text { text: single.year; font-size: 12px; color: #6a6a6a; }
                                                        }
                                                    }
                                                    single-card-ta := TouchArea { clicked => { navigate-to-album(single.browse-id); } }
                                                }
                                            }
                                        }
                                    }
                                }
                                // Videos
                                if artist-view-videos.length > 0: VerticalLayout {
                                    padding-left: 32px; padding-right: 32px; padding-top: 40px; spacing: 16px;
                                    Text { text: "Videos"; font-size: 22px; font-weight: 700; color: #ffffff; }
                                    Rectangle {
                                        height: 210px; clip: true;
                                        Flickable {
                                            width: parent.width; height: parent.height;
                                            viewport-width: videos-row.preferred-width + 16px;
                                            videos-row := HorizontalLayout {
                                                spacing: 16px;
                                                for vid[i] in artist-view-videos: Rectangle {
                                                    width: 200px; height: 200px; border-radius: 8px;
                                                    background: vid-card-ta.has-hover ? #1a1a1a : #121212;
                                                    animate background { duration: 120ms; }
                                                    VerticalLayout {
                                                        padding: 8px; spacing: 8px;
                                                        Rectangle {
                                                            width: 184px; height: 104px; border-radius: 8px; clip: true;
                                                            background: #1a1a1a;
                                                            if vid.has-thumbnail: Image {
                                                                source: vid.thumbnail;
                                                                width: parent.width; height: parent.height; image-fit: cover;
                                                            }
                                                            if !vid.has-thumbnail: Text {
                                                                text: "▶"; font-size: 36px; color: #4a4a4a;
                                                                horizontal-alignment: center; vertical-alignment: center;
                                                            }
                                                        }
                                                        VerticalLayout {
                                                            spacing: 2px; padding-left: 4px;
                                                            Text { text: vid.title; font-size: 13px; font-weight: 600; color: #e0e0e0; overflow: elide; }
                                                            Text { text: vid.duration-str; font-size: 12px; color: #6a6a6a; }
                                                        }
                                                    }
                                                    vid-card-ta := TouchArea { clicked => {
                                                        play-song(vid.video-id, vid.title, vid.artist, vid.duration-secs);
                                                    } }
                                                }
                                            }
                                        }
                                    }
                                }
                                // Fans also like
                                if artist-view-related.length > 0: VerticalLayout {
                                    padding-left: 32px; padding-right: 32px; padding-top: 40px; spacing: 16px;
                                    Text { text: "Fans also like"; font-size: 22px; font-weight: 700; color: #ffffff; }
                                    Rectangle {
                                        height: 220px; clip: true;
                                        Flickable {
                                            width: parent.width; height: parent.height;
                                            viewport-width: related-row.preferred-width + 16px;
                                            related-row := HorizontalLayout {
                                                spacing: 16px;
                                                for ra[i] in artist-view-related: Rectangle {
                                                    width: 160px; height: 210px; border-radius: 8px;
                                                    background: ra-card-ta.has-hover ? #1a1a1a : #121212;
                                                    animate background { duration: 120ms; }
                                                    VerticalLayout {
                                                        padding: 8px; spacing: 8px;
                                                        Rectangle {
                                                            width: 120px; height: 120px; border-radius: 60px; clip: true;
                                                            background: #252525;
                                                            if ra.has-thumbnail: Image {
                                                                source: ra.thumbnail;
                                                                width: parent.width; height: parent.height; image-fit: cover;
                                                            }
                                                            if !ra.has-thumbnail: Text {
                                                                text: "♪"; font-size: 36px; color: #4a4a4a;
                                                                horizontal-alignment: center; vertical-alignment: center;
                                                            }
                                                        }
                                                        VerticalLayout {
                                                            spacing: 2px;
                                                            Text { text: ra.name; font-size: 13px; font-weight: 600; color: #e0e0e0; overflow: elide; horizontal-alignment: center; }
                                                            Text { text: ra.subscriber-count; font-size: 11px; color: #6a6a6a; horizontal-alignment: center; }
                                                        }
                                                    }
                                                    ra-card-ta := TouchArea { clicked => { navigate-to-artist(ra.browse-id); } }
                                                }
                                            }
                                        }
                                    }
                                }
                                // About the artist
                                if artist-view-description != "": VerticalLayout {
                                    padding-left: 32px; padding-right: 32px; padding-top: 40px; spacing: 12px;
                                    Text { text: "About"; font-size: 22px; font-weight: 700; color: #ffffff; }
                                    Rectangle {
                                        border-radius: 12px; background: #1a1a1a;
                                        VerticalLayout {
                                            padding: 20px; spacing: 8px;
                                            Text { text: artist-view-description; font-size: 14px; color: #b0b0b0; wrap: word-wrap; }
                                        }
                                    }
                                }
                                Rectangle { height: 40px; }
                            }
                        }

                        // ALBUM
                        if !is-loading && current-view == "Album": Flickable {
                            viewport-height: album-col.preferred-height + 60px;
                            album-col := VerticalLayout {
                                spacing: 0px;
                                Rectangle {
                                    height: 280px;
                                    background: @linear-gradient(180deg, #6a3a00 0%, #2a1500 60%, #000000 100%);
                                    clip: true;
                                    HorizontalLayout {
                                        padding: 32px; padding-top: 48px; spacing: 24px; alignment: start;
                                        Rectangle {
                                            width: 180px; height: 180px; border-radius: 8px; clip: true;
                                            background: #1a1a1a;
                                            drop-shadow-blur: 24px; drop-shadow-color: #00000080; drop-shadow-offset-y: 8px;
                                            if album-view-has-thumbnail: Image {
                                                source: album-view-thumbnail;
                                                width: parent.width; height: parent.height; image-fit: cover;
                                            }
                                            if !album-view-has-thumbnail: Text {
                                                text: "💿"; font-size: 60px;
                                                horizontal-alignment: center; vertical-alignment: center;
                                            }
                                        }
                                        VerticalLayout {
                                            alignment: center; spacing: 6px;
                                            Text { text: "Album"; font-size: 12px; font-weight: 600; color: #a0a0a0; letter-spacing: 0.5px; }
                                            Text { text: album-view-title; font-size: 28px; font-weight: 800; color: #ffffff; overflow: elide; }
                                            HorizontalLayout {
                                                spacing: 8px; alignment: start;
                                                Text { text: album-view-artist; font-size: 14px; font-weight: 500; color: #e0e0e0; }
                                                if album-view-year != "": Text { text: "•"; font-size: 14px; color: #6a6a6a; }
                                                if album-view-year != "": Text { text: album-view-year; font-size: 14px; color: #a0a0a0; }
                                            }
                                            Text {
                                text: album-view-duration != "" ? "\{album-view-songs.length} songs • " + album-view-duration : "\{album-view-songs.length} songs";
                                font-size: 13px; color: #6a6a6a;
                            }
                                            Rectangle { height: 12px; }
                                            HorizontalLayout {
                                                spacing: 12px; alignment: start;
                                                Rectangle {
                                                    width: 120px; height: 44px; border-radius: 22px;
                                                    background: album-play-ta.has-hover ? #1ed760 : #1db954;
                                                    HorizontalLayout {
                                                        alignment: center; spacing: 8px;
                                                        Image { source: @image-url("icons/play.svg"); width: 20px; height: 20px; colorize: #000000; vertical-alignment: center; }
                                                        Text { text: "Play"; font-size: 15px; font-weight: 700; color: #000000; vertical-alignment: center; }
                                                    }
                                                    album-play-ta := TouchArea { clicked => { play-album(); } }
                                                }
                                                // Like album button
                                                Rectangle {
                                                    width: 44px; height: 44px; border-radius: 22px;
                                                    background: album-like-ta.has-hover ? #ffffff14 : transparent;
                                                    Image {
                                                        source: @image-url("icons/heart.svg");
                                                        width: album-view-liked ? 22px : 20px;
                                                        height: album-view-liked ? 22px : 20px;
                                                        colorize: album-view-liked ? #e85d5d : #8a8a8a;
                                                        x: (parent.width - self.width) / 2;
                                                        y: (parent.height - self.height) / 2;
                                                        animate colorize { duration: 200ms; }
                                                        animate width, height { duration: 150ms; easing: ease-out-back; }
                                                    }
                                                    album-like-ta := TouchArea { clicked => { toggle-like-album(); } }
                                                }
                                            }
                                        }
                                    }
                                }
                                VerticalLayout {
                                    padding-left: 32px; padding-right: 32px; padding-top: 24px; spacing: 2px;
                                    for item[i] in album-view-songs: SongRow {
                                        song-title: item.title; song-artist: item.artist;
                                        song-album: ""; song-duration: item.duration-str;
                                        idx-str: "\{i + 1}"; avatar-letter: item.avatar-letter;
                                        thumbnail: item.thumbnail; has-thumbnail: item.has-thumbnail;
                                        is-current: item.video-id == now-playing-video-id;
                                        play-clicked => { play-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                        queue-clicked => { queue-song(item.video-id, item.title, item.artist); }
                                        play-next-clicked => { play-next-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                        dislike-clicked => { dislike-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                        song-radio-clicked => { start-song-radio(item.video-id); }
                                        go-to-artist-clicked => { go-to-song-artist(item.artist); }
                                    }
                                }
                                // Album description
                                if album-view-description != "": VerticalLayout {
                                    padding-left: 32px; padding-right: 32px; padding-top: 32px; spacing: 12px;
                                    Text { text: "About this album"; font-size: 18px; font-weight: 700; color: #ffffff; }
                                    Rectangle {
                                        border-radius: 12px; background: #1a1a1a;
                                        VerticalLayout {
                                            padding: 16px; spacing: 8px;
                                            Text { text: album-view-description; font-size: 13px; color: #b0b0b0; wrap: word-wrap; }
                                        }
                                    }
                                }
                                // More by this artist
                                if album-view-more-by-artist.length > 0: VerticalLayout {
                                    padding-left: 32px; padding-right: 32px; padding-top: 40px; spacing: 16px;
                                    Text { text: "More by " + album-view-artist; font-size: 22px; font-weight: 700; color: #ffffff; }
                                    Rectangle {
                                        height: 230px; clip: true;
                                        Flickable {
                                            width: parent.width; height: parent.height;
                                            viewport-width: more-artist-row.preferred-width + 16px;
                                            more-artist-row := HorizontalLayout {
                                                spacing: 16px;
                                                for album[i] in album-view-more-by-artist: Rectangle {
                                                    width: 176px; height: 220px; border-radius: 8px;
                                                    background: more-card-ta.has-hover ? #1a1a1a : #121212;
                                                    animate background { duration: 120ms; }
                                                    VerticalLayout {
                                                        padding: 8px; spacing: 8px;
                                                        Rectangle {
                                                            width: 160px; height: 160px; border-radius: 8px; clip: true;
                                                            background: #1a1a1a;
                                                            if album.has-thumbnail: Image {
                                                                source: album.thumbnail;
                                                                width: parent.width; height: parent.height; image-fit: cover;
                                                            }
                                                            if !album.has-thumbnail: Text {
                                                                text: "\u{1f4bf}"; font-size: 40px;
                                                                horizontal-alignment: center; vertical-alignment: center;
                                                            }
                                                        }
                                                        VerticalLayout {
                                                            spacing: 2px; padding-left: 4px;
                                                            Text { text: album.title; font-size: 13px; font-weight: 600; color: #e0e0e0; overflow: elide; }
                                                            Text { text: album.year; font-size: 12px; color: #6a6a6a; }
                                                        }
                                                    }
                                                    more-card-ta := TouchArea { clicked => { navigate-to-album(album.browse-id); } }
                                                }
                                            }
                                        }
                                    }
                                }
                                // You might also like
                                if album-view-similar.length > 0: VerticalLayout {
                                    padding-left: 32px; padding-right: 32px; padding-top: 40px; spacing: 16px;
                                    Text { text: "You might also like"; font-size: 22px; font-weight: 700; color: #ffffff; }
                                    Rectangle {
                                        height: 230px; clip: true;
                                        Flickable {
                                            width: parent.width; height: parent.height;
                                            viewport-width: similar-row.preferred-width + 16px;
                                            similar-row := HorizontalLayout {
                                                spacing: 16px;
                                                for album[i] in album-view-similar: Rectangle {
                                                    width: 176px; height: 220px; border-radius: 8px;
                                                    background: similar-card-ta.has-hover ? #1a1a1a : #121212;
                                                    animate background { duration: 120ms; }
                                                    VerticalLayout {
                                                        padding: 8px; spacing: 8px;
                                                        Rectangle {
                                                            width: 160px; height: 160px; border-radius: 8px; clip: true;
                                                            background: #1a1a1a;
                                                            if album.has-thumbnail: Image {
                                                                source: album.thumbnail;
                                                                width: parent.width; height: parent.height; image-fit: cover;
                                                            }
                                                            if !album.has-thumbnail: Text {
                                                                text: "\u{1f4bf}"; font-size: 40px;
                                                                horizontal-alignment: center; vertical-alignment: center;
                                                            }
                                                        }
                                                        VerticalLayout {
                                                            spacing: 2px; padding-left: 4px;
                                                            Text { text: album.title; font-size: 13px; font-weight: 600; color: #e0e0e0; overflow: elide; }
                                                            Text { text: album.year; font-size: 12px; color: #6a6a6a; }
                                                        }
                                                    }
                                                    similar-card-ta := TouchArea { clicked => { navigate-to-album(album.browse-id); } }
                                                }
                                            }
                                        }
                                    }
                                }
                                Rectangle { height: 40px; }
                            }
                        }

                        // RADIO
                        if !is-loading && current-view == "Radio": Flickable {
                            viewport-height: radio-col.preferred-height + 40px;
                            radio-col := VerticalLayout {
                                padding: 0px;
                                // Hero banner
                                Rectangle {
                                    height: 200px;
                                    background: @linear-gradient(135deg, #1db954 0%, #191414 100%);
                                    VerticalLayout {
                                        padding-left: 32px; padding-top: 40px; spacing: 12px;
                                        Text { text: radio-title; font-size: 28px; font-weight: 700; color: #ffffff; }
                                        Text { text: radio-songs.length == 0 ? "" : "\{radio-songs.length} songs"; font-size: 14px; color: #ffffffaa; }
                                        Rectangle { height: 12px; }
                                        Rectangle {
                                            width: 120px; height: 44px; border-radius: 22px;
                                            background: radio-play-ta.has-hover ? #1ed760 : #1db954;
                                            HorizontalLayout {
                                                alignment: center; spacing: 8px;
                                                Image { source: @image-url("icons/play.svg"); width: 20px; height: 20px; colorize: #000000; vertical-alignment: center; }
                                                Text { text: "Play"; font-size: 15px; font-weight: 700; color: #000000; vertical-alignment: center; }
                                            }
                                            radio-play-ta := TouchArea { clicked => { play-radio(); } }
                                        }
                                    }
                                }
                                // Song list
                                VerticalLayout {
                                    padding-left: 16px; padding-right: 16px; padding-top: 16px; spacing: 2px;
                                    for item[i] in radio-songs: SongRow {
                                        song-title: item.title; song-artist: item.artist;
                                        song-album: ""; song-duration: item.duration-str;
                                        idx-str: "\{i + 1}"; avatar-letter: item.avatar-letter;
                                        thumbnail: item.thumbnail; has-thumbnail: item.has-thumbnail;
                                        is-current: item.video-id == now-playing-video-id;
                                        play-clicked => { play-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                        queue-clicked => { queue-song(item.video-id, item.title, item.artist); }
                                        play-next-clicked => { play-next-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                        dislike-clicked => { dislike-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                        song-radio-clicked => { start-song-radio(item.video-id); }
                                        go-to-artist-clicked => { go-to-song-artist(item.artist); }
                                    }
                                }
                                Rectangle { height: 40px; }
                            }
                        }

                        // PLAYLIST
                        if !is-loading && current-view == "Playlist": Flickable {
                            viewport-height: playlist-col.preferred-height + 60px;
                            playlist-col := VerticalLayout {
                                spacing: 0px;
                                // Hero banner
                                Rectangle {
                                    height: 280px;
                                    background: @linear-gradient(180deg, #1a3a6a 0%, #0a1530 60%, #000000 100%);
                                    clip: true;
                                    HorizontalLayout {
                                        padding: 32px; padding-top: 48px; spacing: 24px; alignment: start;
                                        // Thumbnail
                                        Rectangle {
                                            width: 180px; height: 180px; border-radius: 8px; clip: true;
                                            background: #1a1a1a;
                                            drop-shadow-blur: 24px; drop-shadow-color: #00000080; drop-shadow-offset-y: 8px;
                                            if playlist-view-has-thumbnail: Image {
                                                source: playlist-view-thumbnail;
                                                width: parent.width; height: parent.height; image-fit: cover;
                                            }
                                            if !playlist-view-has-thumbnail: Text {
                                                text: "\u{1f3b6}"; font-size: 48px;
                                                horizontal-alignment: center; vertical-alignment: center;
                                            }
                                        }
                                        // Metadata
                                        VerticalLayout {
                                            alignment: center; spacing: 6px;
                                            Text { text: "Playlist"; font-size: 12px; font-weight: 600; color: #a0a0a0; }
                                            Text { text: playlist-view-title; font-size: 28px; font-weight: 800; color: #ffffff; overflow: elide; }
                                            Text { text: playlist-view-count + " songs \u{2022} " + playlist-view-duration; font-size: 13px; color: #6a6a6a; }
                                            Rectangle { height: 12px; }
                                            HorizontalLayout {
                                                spacing: 12px; alignment: start;
                                                // Play button
                                                Rectangle {
                                                    width: 120px; height: 44px; border-radius: 22px;
                                                    background: playlist-play-ta.has-hover ? #1ed760 : #1db954;
                                                    HorizontalLayout {
                                                        alignment: center; spacing: 8px;
                                                        Image { source: @image-url("icons/play.svg"); width: 20px; height: 20px; colorize: #000000; vertical-alignment: center; }
                                                        Text { text: "Play"; font-size: 15px; font-weight: 700; color: #000000; vertical-alignment: center; }
                                                    }
                                                    playlist-play-ta := TouchArea { clicked => { play-playlist(); } }
                                                }
                                                // Like playlist button
                                                Rectangle {
                                                    width: 44px; height: 44px; border-radius: 22px;
                                                    background: pl-like-ta.has-hover ? #ffffff14 : transparent;
                                                    Image {
                                                        source: @image-url("icons/heart.svg");
                                                        width: playlist-view-liked ? 22px : 20px;
                                                        height: playlist-view-liked ? 22px : 20px;
                                                        colorize: playlist-view-liked ? #e85d5d : #8a8a8a;
                                                        x: (parent.width - self.width) / 2;
                                                        y: (parent.height - self.height) / 2;
                                                        animate colorize { duration: 200ms; }
                                                        animate width, height { duration: 150ms; easing: ease-out-back; }
                                                    }
                                                    pl-like-ta := TouchArea { clicked => { toggle-like-playlist(); } }
                                                }
                                            }
                                        }
                                    }
                                }
                                // Song list
                                VerticalLayout {
                                    padding-left: 32px; padding-right: 32px; padding-top: 24px; spacing: 2px;
                                    for item[i] in playlist-view-songs: SongRow {
                                        song-title: item.title; song-artist: item.artist;
                                        song-album: item.album; song-duration: item.duration-str;
                                        idx-str: "\{i + 1}"; avatar-letter: item.avatar-letter;
                                        thumbnail: item.thumbnail; has-thumbnail: item.has-thumbnail;
                                        is-current: item.video-id == now-playing-video-id;
                                        play-clicked => { play-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                        queue-clicked => { queue-song(item.video-id, item.title, item.artist); }
                                        play-next-clicked => { play-next-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                        dislike-clicked => { dislike-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                        song-radio-clicked => { start-song-radio(item.video-id); }
                                        go-to-artist-clicked => { go-to-song-artist(item.artist); }
                                        go-to-album-clicked => { go-to-song-album(item.album); }
                                    }
                                }
                                // Similar playlists
                                if playlist-view-similar.length > 0: VerticalLayout {
                                    padding-left: 32px; padding-right: 32px; padding-top: 40px; spacing: 16px;
                                    Text { text: "Similar playlists"; font-size: 22px; font-weight: 700; color: #ffffff; }
                                    Rectangle {
                                        height: 230px; clip: true;
                                        Flickable {
                                            width: parent.width; height: parent.height;
                                            viewport-width: similar-pl-row.preferred-width + 16px;
                                            similar-pl-row := HorizontalLayout {
                                                spacing: 16px;
                                                for pl[i] in playlist-view-similar: Rectangle {
                                                    width: 176px; height: 220px; border-radius: 8px;
                                                    background: similar-pl-ta.has-hover ? #1a1a1a : #121212;
                                                    animate background { duration: 120ms; }
                                                    VerticalLayout {
                                                        padding: 8px; spacing: 8px;
                                                        Rectangle {
                                                            width: 160px; height: 160px; border-radius: 8px; clip: true;
                                                            background: #1a1a1a;
                                                            if pl.has-thumbnail: Image {
                                                                source: pl.thumbnail;
                                                                width: parent.width; height: parent.height; image-fit: cover;
                                                            }
                                                            if !pl.has-thumbnail: Text {
                                                                text: "\u{1f3b6}"; font-size: 40px;
                                                                horizontal-alignment: center; vertical-alignment: center;
                                                            }
                                                        }
                                                        VerticalLayout {
                                                            spacing: 2px; padding-left: 4px;
                                                            Text { text: pl.title; font-size: 13px; font-weight: 600; color: #e0e0e0; overflow: elide; }
                                                            Text { text: pl.count-text; font-size: 12px; color: #6a6a6a; }
                                                        }
                                                    }
                                                    similar-pl-ta := TouchArea { clicked => { navigate-to-playlist(pl.playlist-id); } }
                                                }
                                            }
                                        }
                                    }
                                }
                                Rectangle { height: 40px; }
                            }
                        }

                        // EXPLORE
                        if !is-loading && current-view == "Explore": Flickable {
                            viewport-height: explore-col.preferred-height + 40px;
                            explore-col := VerticalLayout {
                                padding: 32px; spacing: 20px;
                                Text { text: "Explore"; font-size: 28px; font-weight: 700; color: #ffffff; }
                                Text { text: "Pick a vibe — we'll build your queue"; font-size: 14px; color: #6a6a6a; }

                                // ── Moods & Genres (dynamic from API) ──
                                if explore-moods.length > 0: VerticalLayout {
                                    spacing: 12px;
                                    Rectangle { height: 8px; }
                                    Text { text: "Moods & Genres"; font-size: 18px; font-weight: 600; color: #e0e0e0; }
                                    VerticalLayout {
                                        spacing: 10px;
                                        for mood[i] in explore-moods: Rectangle {
                                            height: 52px; border-radius: 10px;
                                            background: mood-ta.has-hover ? Colors.white.with-alpha(0.08) : Colors.white.with-alpha(0.04);
                                            animate background { duration: 100ms; }
                                            HorizontalLayout {
                                                padding-left: 16px; padding-right: 16px; spacing: 12px; alignment: start;
                                                Rectangle {
                                                    width: 36px; height: 36px; border-radius: 8px;
                                                    background: i == 0 ? #5020a0 : i == 1 ? #8a2020 : i == 2 ? #1a4070 : i == 3 ? #7a3010 : i == 4 ? #0a2a2a : i == 5 ? #401a50 : i == 6 ? #1a2a10 : i == 7 ? #2a3050 : i == 8 ? #6a1a4a : #1a5040;
                                                    Text {
                                                        text: "♪";
                                                        font-size: 16px; color: #ffffff;
                                                        horizontal-alignment: center; vertical-alignment: center;
                                                    }
                                                }
                                                Text {
                                                    text: mood.title;
                                                    font-size: 14px; font-weight: 500; color: #ffffff;
                                                    vertical-alignment: center;
                                                }
                                            }
                                            mood-ta := TouchArea { clicked => { explore-mood(mood.params); } }
                                        }
                                    }
                                }

                                // ── Quick Genres ──
                                Rectangle { height: 8px; }
                                Text { text: "Quick Genres"; font-size: 18px; font-weight: 600; color: #e0e0e0; }
                                GridLayout {
                                    spacing: 14px;
                                    Row {
                                        GenreTile { label: "Pop";          icon: "🎵"; tile-color: #5020a0; clicked => { explore-genre("pop music hits"); } }
                                        GenreTile { label: "Hip-Hop";      icon: "🎤"; tile-color: #8a2020; clicked => { explore-genre("hip hop rap"); } }
                                    }
                                    Row {
                                        GenreTile { label: "Electronic";   icon: "⚡"; tile-color: #1a4070; clicked => { explore-genre("electronic edm dance"); } }
                                        GenreTile { label: "Rock";         icon: "🎸"; tile-color: #2a3050; clicked => { explore-genre("rock music"); } }
                                    }
                                    Row {
                                        GenreTile { label: "Bollywood";    icon: "🎭"; tile-color: #7a3010; clicked => { explore-genre("bollywood hindi songs"); } }
                                        GenreTile { label: "Lofi Chill";   icon: "🌙"; tile-color: #0a2a2a; clicked => { explore-genre("lofi chill study beats"); } }
                                    }
                                    Row {
                                        GenreTile { label: "Classical";    icon: "🎻"; tile-color: #1a2a10; clicked => { explore-genre("classical orchestral piano"); } }
                                        GenreTile { label: "K-Pop";        icon: "✨"; tile-color: #401a50; clicked => { explore-genre("kpop korean pop"); } }
                                    }
                                }

                                // ── New Releases ──
                                if explore-new-releases.length > 0: VerticalLayout {
                                    spacing: 12px;
                                    Rectangle { height: 8px; }
                                    Text { text: "New Releases"; font-size: 18px; font-weight: 600; color: #e0e0e0; }
                                    Flickable {
                                        height: 280px;
                                        viewport-width: explore-new-releases.length * 214px;
                                        HorizontalLayout {
                                            spacing: 14px;
                                            for item in explore-new-releases: SongCard {
                                                card-title: item.title;
                                                card-artist: item.artist;
                                                avatar-letter: item.avatar-letter;
                                                thumbnail: item.thumbnail;
                                                has-thumbnail: item.has-thumbnail;
                                                video-id: item.video-id;
                                                is-now-playing: item.video-id == now-playing-video-id;
                                                is-playing: item.video-id == now-playing-video-id && is-playing;
                                                clicked => { play-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                                queue-clicked => { queue-song(item.video-id, item.title, item.artist); }
                                                play-next-clicked => { play-next-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                                song-radio-clicked => { start-song-radio(item.video-id); }
                                                go-to-artist-clicked => { go-to-song-artist(item.artist); }
                                            }
                                        }
                                    }
                                }

                                // ── Charts ──
                                Rectangle { height: 8px; }
                                Text { text: "Charts"; font-size: 18px; font-weight: 600; color: #e0e0e0; }
                                GridLayout {
                                    spacing: 14px;
                                    Row {
                                        GenreTile { label: "Top 100 Global";  icon: "🌍"; tile-color: #1a3a6a; clicked => { explore-genre("top 100 global hits 2026"); } }
                                        GenreTile { label: "Top 50 USA";      icon: "🇺🇸"; tile-color: #2a1a5a; clicked => { explore-genre("top 50 USA hits 2026"); } }
                                    }
                                    Row {
                                        GenreTile { label: "Top 50 India";    icon: "🇮🇳"; tile-color: #5a2a0a; clicked => { explore-genre("top 50 India hits 2026"); } }
                                        GenreTile { label: "Top 50 UK";       icon: "🇬🇧"; tile-color: #0a3a3a; clicked => { explore-genre("top 50 UK hits 2026"); } }
                                    }
                                }
                                Rectangle { height: 40px; }
                            }
                        }

                        // LIBRARY
                        if !is-loading && current-view == "Library": Flickable {
                            viewport-height: lib-col.preferred-height + 40px;
                            lib-col := VerticalLayout {
                                padding: 32px; spacing: 10px;
                                Text { text: "Your Library"; font-size: 28px; font-weight: 700; color: #ffffff; }
                                HorizontalLayout {
                                    height: 40px; spacing: 8px; alignment: start;
                                    TabPill { label: "Liked Songs (\{liked-songs.length})"; active: library-tab == "Liked"; clicked => { library-tab = "Liked"; } }
                                    TabPill { label: "Albums"; active: library-tab == "Albums"; clicked => { library-tab = "Albums"; load-library-data(); } }
                                    TabPill { label: "Artists"; active: library-tab == "Artists"; clicked => { library-tab = "Artists"; load-library-data(); } }
                                    TabPill { label: "Playlists"; active: library-tab == "Playlists"; clicked => { library-tab = "Playlists"; load-library-data(); } }
                                }
                                Rectangle { height: 4px; }
                                // Sort pills for Liked Songs tab
                                if library-tab == "Liked": HorizontalLayout {
                                    height: 30px; spacing: 6px; alignment: start;
                                    TabPill { label: "Recent"; active: library-sort == "recent"; clicked => { library-sort = "recent"; sort-library("recent"); } }
                                    TabPill { label: "A-Z"; active: library-sort == "alpha"; clicked => { library-sort = "alpha"; sort-library("alpha"); } }
                                    TabPill { label: "Most played"; active: library-sort == "most-played"; clicked => { library-sort = "most-played"; sort-library("most-played"); } }
                                }
                                Rectangle { height: 4px; }
                                // ── Liked Songs tab ──
                                if library-tab == "Liked": VerticalLayout {
                                    spacing: 2px;
                                    for item[i] in liked-songs: SongRow {
                                        song-title: item.title; song-artist: item.artist;
                                        song-album: item.album; song-duration: item.duration-str;
                                        idx-str: "\{i + 1}"; avatar-letter: item.avatar-letter;
                                        thumbnail: item.thumbnail; has-thumbnail: item.has-thumbnail;
                                        is-current: item.video-id == now-playing-video-id;
                                        show-unlike: true;
                                        play-clicked => { play-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                        queue-clicked => { queue-song(item.video-id, item.title, item.artist); }
                                        play-next-clicked => { play-next-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                        unlike-clicked => { unlike-song(item.video-id); }
                                        dislike-clicked => { dislike-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                        song-radio-clicked => { start-song-radio(item.video-id); }
                                        go-to-artist-clicked => { go-to-song-artist(item.artist); }
                                        go-to-album-clicked => { go-to-song-album(item.album); }
                                    }
                                    if liked-songs.length == 0: Rectangle {
                                        height: 200px;
                                        VerticalLayout { alignment: center; spacing: 12px;
                                            Text { text: "♥"; font-size: 44px; color: #2a2a2a; horizontal-alignment: center; }
                                            Text { text: "No liked songs yet"; font-size: 18px; color: #5a5a5a; horizontal-alignment: center; }
                                            Text { text: "Tap ♥ while a song plays"; font-size: 13px; color: #3a3a3a; horizontal-alignment: center; }
                                        }
                                    }
                                }
                                // ── Albums tab ──
                                if library-tab == "Albums": VerticalLayout {
                                    spacing: 12px;
                                    if library-albums.length == 0: Rectangle {
                                        height: 200px;
                                        VerticalLayout { alignment: center; spacing: 12px;
                                            Text { text: "💿"; font-size: 44px; color: #2a2a2a; horizontal-alignment: center; }
                                            Text { text: "No albums yet"; font-size: 18px; color: #5a5a5a; horizontal-alignment: center; }
                                            Text { text: "Albums from your liked songs appear here"; font-size: 13px; color: #3a3a3a; horizontal-alignment: center; }
                                        }
                                    }
                                    for alb[i] in library-albums: Rectangle {
                                        height: 64px; border-radius: 8px;
                                        background: lib-alb-ta.has-hover ? #ffffff0c : transparent;
                                        animate background { duration: 100ms; }
                                        HorizontalLayout {
                                            padding-left: 8px; padding-right: 12px; spacing: 12px; alignment: start;
                                            Rectangle {
                                                width: 48px; height: 48px; border-radius: 6px; clip: true;
                                                background: #1a1a1a;
                                                y: (parent.height - self.height) / 2;
                                                if alb.has-thumbnail: Image {
                                                    source: alb.thumbnail;
                                                    width: parent.width; height: parent.height; image-fit: cover;
                                                }
                                                if !alb.has-thumbnail: Text {
                                                    text: "💿"; font-size: 20px;
                                                    horizontal-alignment: center; vertical-alignment: center;
                                                }
                                            }
                                            VerticalLayout {
                                                alignment: center; spacing: 3px;
                                                Text { text: alb.title; font-size: 14px; font-weight: 600; color: #e0e0e0; overflow: elide; }
                                                HorizontalLayout {
                                                    spacing: 6px; alignment: start;
                                                    Text { text: "Album"; font-size: 12px; color: #6a6a6a; }
                                                    Text { text: "•"; font-size: 12px; color: #4a4a4a; }
                                                    Text { text: alb.artist; font-size: 12px; color: #8a8a8a; overflow: elide; }
                                                }
                                            }
                                        }
                                        lib-alb-ta := TouchArea { clicked => { navigate-to-album(alb.browse-id); } }
                                    }
                                }
                                // ── Artists tab ──
                                if library-tab == "Artists": VerticalLayout {
                                    spacing: 12px;
                                    if library-artists.length == 0: Rectangle {
                                        height: 200px;
                                        VerticalLayout { alignment: center; spacing: 12px;
                                            Text { text: "🎤"; font-size: 44px; color: #2a2a2a; horizontal-alignment: center; }
                                            Text { text: "No artists yet"; font-size: 18px; color: #5a5a5a; horizontal-alignment: center; }
                                            Text { text: "Artists from your liked songs appear here"; font-size: 13px; color: #3a3a3a; horizontal-alignment: center; }
                                        }
                                    }
                                    for art[i] in library-artists: Rectangle {
                                        height: 64px; border-radius: 8px;
                                        background: lib-art-ta.has-hover ? #ffffff0c : transparent;
                                        animate background { duration: 100ms; }
                                        HorizontalLayout {
                                            padding-left: 8px; padding-right: 12px; spacing: 12px; alignment: start;
                                            Rectangle {
                                                width: 48px; height: 48px; border-radius: 24px; clip: true;
                                                background: #1a1a1a;
                                                y: (parent.height - self.height) / 2;
                                                if art.has-thumbnail: Image {
                                                    source: art.thumbnail;
                                                    width: parent.width; height: parent.height; image-fit: cover;
                                                }
                                                if !art.has-thumbnail: Text {
                                                    text: art.name.character-count > 0 ? art.name : "?"; font-size: 18px; color: #4a4a4a;
                                                    horizontal-alignment: center; vertical-alignment: center;
                                                }
                                            }
                                            VerticalLayout {
                                                alignment: center; spacing: 3px;
                                                Text { text: art.name; font-size: 14px; font-weight: 600; color: #e0e0e0; overflow: elide; }
                                                Text { text: "Artist"; font-size: 12px; color: #6a6a6a; }
                                            }
                                        }
                                        lib-art-ta := TouchArea { clicked => { navigate-to-artist(art.browse-id); } }
                                    }
                                }
                                // ── Playlists tab ──
                                if library-tab == "Playlists": VerticalLayout {
                                    spacing: 12px;
                                    if library-playlists.length == 0: Rectangle {
                                        height: 200px;
                                        VerticalLayout { alignment: center; spacing: 12px;
                                            Text { text: "🎶"; font-size: 44px; color: #2a2a2a; horizontal-alignment: center; }
                                            Text { text: "No playlists yet"; font-size: 18px; color: #5a5a5a; horizontal-alignment: center; }
                                            Text { text: "Your playlists will appear here"; font-size: 13px; color: #3a3a3a; horizontal-alignment: center; }
                                        }
                                    }
                                    for pl[i] in library-playlists: Rectangle {
                                        height: 64px; border-radius: 8px;
                                        background: pl-ta.has-hover ? #ffffff0c : transparent;
                                        animate background { duration: 100ms; }
                                        HorizontalLayout {
                                            padding-left: 8px; padding-right: 12px; spacing: 12px; alignment: start;
                                            Rectangle {
                                                width: 48px; height: 48px; border-radius: 6px; clip: true;
                                                background: #1a1a1a;
                                                y: (parent.height - self.height) / 2;
                                                if pl.has-thumbnail: Image {
                                                    source: pl.thumbnail;
                                                    width: parent.width; height: parent.height; image-fit: cover;
                                                }
                                                if !pl.has-thumbnail: Text {
                                                    text: "🎶"; font-size: 20px;
                                                    horizontal-alignment: center; vertical-alignment: center;
                                                }
                                            }
                                            VerticalLayout {
                                                alignment: center; spacing: 3px;
                                                Text { text: pl.title; font-size: 14px; font-weight: 600; color: #e0e0e0; overflow: elide; }
                                                HorizontalLayout {
                                                    spacing: 6px; alignment: start;
                                                    Text { text: "Playlist"; font-size: 12px; color: #6a6a6a; }
                                                    if pl.count-text != "": Text { text: "•"; font-size: 12px; color: #4a4a4a; }
                                                    if pl.count-text != "": Text { text: pl.count-text; font-size: 12px; color: #8a8a8a; }
                                                }
                                            }
                                        }
                                        pl-ta := TouchArea { clicked => { navigate-to-playlist(pl.playlist-id); } }
                                    }
                                }
                            }
                        }

                        // SETTINGS
                        if !is-loading && current-view == "Settings": Flickable {
                            viewport-height: set-col.preferred-height + 40px;
                            set-col := VerticalLayout {
                                padding: 32px; spacing: 24px;
                                Text { text: "Settings"; font-size: 28px; font-weight: 700; color: #ffffff; }
                                // About
                                Rectangle {
                                    height: 72px; border-radius: 12px;
                                    background: #0f0f0f; border-color: #1a1a1a; border-width: 1px;
                                    HorizontalLayout {
                                        padding: 20px; spacing: 14px; alignment: start;
                                        Text { text: "▶"; color: #e85d5d; font-size: 26px; vertical-alignment: center; }
                                        VerticalLayout { alignment: center; spacing: 4px;
                                            Text { text: "Auricle"; font-size: 16px; font-weight: 600; color: #ffffff; }
                                            Text { text: "Native • Rust + Slint"; font-size: 12px; color: #5a5a5a; }
                                        }
                                    }
                                }
                                // Essential add-ons
                                Text { text: "Essential add-ons"; font-size: 14px; font-weight: 600; color: #808080; }
                                Rectangle {
                                    border-radius: 12px; background: #0f0f0f; border-color: #1a1a1a; border-width: 1px;
                                    VerticalLayout { padding: 18px; spacing: 14px;
                                        Text {
                                            text: "These optional third-party tools are not bundled with Auricle. Installing them is at your own discretion and choice; Auricle is not affiliated with them. You may also install them manually onto your PATH.";
                                            font-size: 12px; color: #6a6a6a; wrap: word-wrap;
                                        }
                                        // yt-dlp row
                                        VerticalLayout { spacing: 10px;
                                            HorizontalLayout { spacing: 12px;
                                                VerticalLayout { alignment: center; spacing: 2px; horizontal-stretch: 1;
                                                    Text { text: "yt-dlp"; font-size: 14px; color: #c0c0c0; }
                                                    Text { text: "Required for audio streaming and downloads."; font-size: 12px; color: #5a5a5a; }
                                                }
                                                if ytdlp-installed && addon-installing != "ytdlp": HorizontalLayout { spacing: 10px; alignment: end;
                                                    Text { text: "✓ Installed"; font-size: 13px; color: #4a9d5a; vertical-alignment: center; }
                                                    Rectangle {
                                                        width: 104px; height: 32px; border-radius: 8px;
                                                        background: addon-busy ? #181818 : (yt-rep-ta.has-hover ? #242424 : transparent);
                                                        border-color: #333333; border-width: 1px;
                                                        animate background { duration: 100ms; }
                                                        Text { text: "Repair install"; font-size: 12px; color: addon-busy ? #5a5a5a : #c0c0c0; horizontal-alignment: center; vertical-alignment: center; }
                                                        yt-rep-ta := TouchArea { clicked => { if !addon-busy { install-ytdlp(); } } }
                                                    }
                                                }
                                                if !ytdlp-installed && addon-installing != "ytdlp": Rectangle {
                                                    width: 92px; height: 32px; border-radius: 8px;
                                                    background: addon-busy ? #181818 : (yt-ins-ta.has-hover ? #f06a6a : #e85d5d);
                                                    animate background { duration: 100ms; }
                                                    Text { text: "Install"; font-size: 13px; color: addon-busy ? #5a5a5a : #ffffff; horizontal-alignment: center; vertical-alignment: center; }
                                                    yt-ins-ta := TouchArea { clicked => { if !addon-busy { install-ytdlp(); } } }
                                                }
                                            }
                                            if addon-installing == "ytdlp": HorizontalLayout { spacing: 10px; alignment: center;
                                                AddonProgress { value: addon-progress; horizontal-stretch: 1; }
                                                Text {
                                                    text: addon-progress < 0 ? "…" : (Math.round(addon-progress * 100) + "%");
                                                    width: 40px; font-size: 11px; color: #8a8a8a; vertical-alignment: center;
                                                }
                                            }
                                        }
                                        Rectangle { height: 1px; background: #1a1a1a; }
                                        // ffmpeg row
                                        VerticalLayout { spacing: 10px;
                                            HorizontalLayout { spacing: 12px;
                                                VerticalLayout { alignment: center; spacing: 2px; horizontal-stretch: 1;
                                                    Text { text: "ffmpeg"; font-size: 14px; color: #c0c0c0; }
                                                    Text { text: "Optional. Improves format handling for downloads."; font-size: 12px; color: #5a5a5a; }
                                                }
                                                if ffmpeg-installed && addon-installing != "ffmpeg": HorizontalLayout { spacing: 10px; alignment: end;
                                                    Text { text: "✓ Installed"; font-size: 13px; color: #4a9d5a; vertical-alignment: center; }
                                                    Rectangle {
                                                        width: 104px; height: 32px; border-radius: 8px;
                                                        background: addon-busy ? #181818 : (ff-rep-ta.has-hover ? #242424 : transparent);
                                                        border-color: #333333; border-width: 1px;
                                                        animate background { duration: 100ms; }
                                                        Text { text: "Repair install"; font-size: 12px; color: addon-busy ? #5a5a5a : #c0c0c0; horizontal-alignment: center; vertical-alignment: center; }
                                                        ff-rep-ta := TouchArea { clicked => { if !addon-busy { install-ffmpeg(); } } }
                                                    }
                                                }
                                                if !ffmpeg-installed && addon-installing != "ffmpeg": Rectangle {
                                                    width: 92px; height: 32px; border-radius: 8px;
                                                    background: addon-busy ? #181818 : (ff-ins-ta.has-hover ? #333333 : #2a2a2a);
                                                    animate background { duration: 100ms; }
                                                    Text { text: "Install"; font-size: 13px; color: addon-busy ? #5a5a5a : #ffffff; horizontal-alignment: center; vertical-alignment: center; }
                                                    ff-ins-ta := TouchArea { clicked => { if !addon-busy { install-ffmpeg(); } } }
                                                }
                                            }
                                            if addon-installing == "ffmpeg": HorizontalLayout { spacing: 10px; alignment: center;
                                                AddonProgress { value: addon-progress; horizontal-stretch: 1; }
                                                Text {
                                                    text: addon-progress < 0 ? "…" : (Math.round(addon-progress * 100) + "%");
                                                    width: 40px; font-size: 11px; color: #8a8a8a; vertical-alignment: center;
                                                }
                                            }
                                        }
                                        if addon-status != "": Text { text: addon-status; font-size: 12px; color: #8a8a8a; wrap: word-wrap; }
                                    }
                                }
                                // Audio
                                Text { text: "Audio"; font-size: 14px; font-weight: 600; color: #808080; }
                                Rectangle {
                                    border-radius: 12px; background: #0f0f0f; border-color: #1a1a1a; border-width: 1px;
                                    VerticalLayout { padding: 18px; spacing: 14px;
                                        HorizontalLayout { alignment: space-between;
                                            Text { text: "Audio quality"; font-size: 14px; color: #c0c0c0; vertical-alignment: center; }
                                            Text { text: "Best available (AAC)"; font-size: 13px; color: #5a5a5a; vertical-alignment: center; }
                                        }
                                        Rectangle { height: 1px; background: #1a1a1a; }
                                        HorizontalLayout { alignment: space-between;
                                            Text { text: "Cookie auth"; font-size: 14px; color: #c0c0c0; vertical-alignment: center; }
                                            Text { text: "Auto: Edge → Chrome → Firefox"; font-size: 13px; color: #5a5a5a; vertical-alignment: center; }
                                        }
                                    }
                                }
                                // Library
                                Text { text: "Library"; font-size: 14px; font-weight: 600; color: #808080; }
                                Rectangle {
                                    border-radius: 12px; background: #0f0f0f; border-color: #1a1a1a; border-width: 1px;
                                    VerticalLayout { padding: 18px; spacing: 14px;
                                        HorizontalLayout { alignment: space-between;
                                            Text { text: "Liked songs"; font-size: 14px; color: #c0c0c0; vertical-alignment: center; }
                                            Text { text: "\{liked-songs.length} songs"; font-size: 13px; color: #5a5a5a; vertical-alignment: center; }
                                        }

                                        Rectangle { height: 1px; background: #1a1a1a; }
                                        HorizontalLayout { alignment: space-between;
                                            Text { text: "Queue length"; font-size: 14px; color: #c0c0c0; vertical-alignment: center; }
                                            Text { text: "\{queue.length} songs"; font-size: 13px; color: #5a5a5a; vertical-alignment: center; }
                                        }
                                    }
                                }
                                // Cache
                                Text { text: "Cache"; font-size: 14px; font-weight: 600; color: #808080; }
                                Rectangle {
                                    border-radius: 12px; background: #0f0f0f; border-color: #1a1a1a; border-width: 1px;
                                    VerticalLayout { padding: 18px; spacing: 14px;
                                        HorizontalLayout { alignment: space-between;
                                            Text { text: "Cached songs"; font-size: 14px; color: #c0c0c0; vertical-alignment: center; }
                                            Text { text: "\{cache-song-count} songs • \{cache-used-mb} MB"; font-size: 13px; color: #5a5a5a; vertical-alignment: center; }
                                        }
                                        Rectangle { height: 1px; background: #1a1a1a; }
                                        VerticalLayout { spacing: 8px;
                                            HorizontalLayout { alignment: space-between;
                                                Text { text: "Storage limit"; font-size: 14px; color: #c0c0c0; vertical-alignment: center; }
                                                Text { text: "\{cache-limit-mb} MB"; font-size: 13px; color: #e85d5d; vertical-alignment: center; font-weight: 600; }
                                            }
                                            Rectangle { height: 4px; border-radius: 2px; background: #1a1a1a;
                                                Rectangle {
                                                    x: 0; y: 0; border-radius: 2px;
                                                    width: max(4px, min(parent.width, parent.width * (cache-used-mb / max(1, cache-limit-mb))));
                                                    background: cache-used-mb > cache-limit-mb * 9 / 10 ? #e85d5d : #4a4a4a;
                                                }
                                            }
                                        }
                                        HorizontalLayout { spacing: 8px; alignment: start;
                                            for mb in [250, 500, 1000, 2000]: Rectangle {
                                                width: 72px; height: 32px; border-radius: 16px;
                                                background: cache-limit-mb == mb ? #e85d5d : #1a1a1a;
                                                Text {
                                                    text: mb >= 1000 ? (mb / 1000) + " GB" : mb + " MB";
                                                    color: cache-limit-mb == mb ? #ffffff : #6a6a6a;
                                                    font-size: 12px; font-weight: 600;
                                                    horizontal-alignment: center; vertical-alignment: center;
                                                }
                                                TouchArea { clicked => { set-cache-limit(mb); } }
                                            }
                                        }
                                        Rectangle { height: 1px; background: #1a1a1a; }
                                        Text { text: "Songs are cached on first play and persist between sessions."; font-size: 12px; color: #4a4a4a; wrap: word-wrap; }
                                        Rectangle { height: 12px; }
                                        Rectangle {
                                            height: 36px; width: 120px; border-radius: 8px;
                                            background: clear-cache-ta.has-hover ? #e53935 : #c62828;
                                            Text { text: "Clear Cache"; font-size: 13px; font-weight: 600; color: #ffffff; horizontal-alignment: center; vertical-alignment: center; }
                                            clear-cache-ta := TouchArea { clicked => { clear-cache(); } }
                                        }
                                    }
                                }
                                // Behavior
                                Text { text: "Behavior"; font-size: 14px; font-weight: 600; color: #808080; }
                                Rectangle {
                                    border-radius: 12px; background: #0f0f0f; border-color: #1a1a1a; border-width: 1px;
                                    VerticalLayout { padding: 18px; spacing: 14px;
                                        HorizontalLayout { alignment: space-between;
                                            VerticalLayout { spacing: 4px; vertical-stretch: 1;
                                                Text { text: "Minimize to tray"; font-size: 14px; color: #c0c0c0; vertical-alignment: center; }
                                                Text { text: "Close button minimizes to system tray instead of quitting"; font-size: 12px; color: #4a4a4a; }
                                            }
                                            // Toggle switch
                                            Rectangle {
                                                width: 44px; height: 24px; border-radius: 12px;
                                                background: minimize-to-tray ? #1db954 : #3a3a3a;
                                                animate background { duration: 150ms; }
                                                Rectangle {
                                                    x: minimize-to-tray ? parent.width - self.width - 2px : 2px;
                                                    y: 2px; width: 20px; height: 20px; border-radius: 10px;
                                                    background: #ffffff;
                                                    animate x { duration: 150ms; easing: ease-out; }
                                                }
                                                TouchArea { clicked => { minimize-to-tray = !minimize-to-tray; set-minimize-to-tray(minimize-to-tray); } }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                // ── Right queue pane (Spotify-style) ─────────────────────────
                if queue-pane-open: Rectangle {
                    width: 320px; background: #121212;
                    Rectangle { x: 0; y: 0; width: 1px; height: parent.height; background: #1a1a1a; }
                    VerticalLayout {
                        padding: 12px; padding-left: 12px; padding-right: 12px; spacing: 0px;
                        // Header
                        HorizontalLayout {
                            height: 40px; alignment: space-between;
                            Text { text: "Queue"; font-size: 16px; font-weight: 700; color: #ffffff; vertical-alignment: center; }
                            HorizontalLayout { spacing: 4px; alignment: center;
                                Text { text: "\{queue.length} songs"; font-size: 12px; color: #5a5a5a; vertical-alignment: center; }
                                IconBtn { svg-icon: @image-url("icons/close.svg"); use-svg: true; icon-color: #5a5a5a; clicked => { toggle-queue-pane(); } }
                            }
                        }
                        Rectangle { height: 12px; }

                        Flickable {
                            vertical-stretch: 1;
                            viewport-height: qpane-col.preferred-height;
                            qpane-col := VerticalLayout {
                                spacing: 0px;

                                // ── Now Playing ──
                                if now-playing-video-id != "": VerticalLayout {
                                    spacing: 8px;
                                    Text { text: "Now playing"; font-size: 14px; font-weight: 700; color: #ffffff; }
                                    Rectangle {
                                        height: 68px; border-radius: 8px;
                                        background: #ffffff0c;
                                        HorizontalLayout {
                                            padding-left: 8px; padding-right: 8px; padding-top: 10px; padding-bottom: 10px; spacing: 10px; alignment: start;
                                            Rectangle {
                                                width: 48px; height: 48px; border-radius: 6px; clip: true;
                                                background: #2a2a2a;
                                                if has-album-art: Image {
                                                    source: album-art; width: parent.width; height: parent.height; image-fit: cover;
                                                }
                                                if !has-album-art: Text {
                                                    text: track-initial; color: #e85d5d; font-size: 16px; font-weight: 700;
                                                    horizontal-alignment: center; vertical-alignment: center;
                                                }
                                            }
                                            VerticalLayout {
                                                alignment: center; spacing: 3px; horizontal-stretch: 1;
                                                Text { text: track-title; font-size: 14px; font-weight: 600; color: #1db954; overflow: elide; }
                                                Text { text: track-artist; font-size: 12px; color: #a0a0a0; overflow: elide; }
                                            }
                                        }
                                    }
                                    Rectangle { height: 16px; }
                                }

                                // ── Next in queue ──
                                Text { text: "Next in queue"; font-size: 14px; font-weight: 700; color: #ffffff; }
                                Rectangle { height: 8px; }

                                for item[i] in queue: Rectangle {
                                    height: 64px;
                                    border-radius: 6px;
                                    background: item.video-id == now-playing-video-id ? #ffffff06 : (qrow-ta.has-hover ? #ffffff0a : transparent);
                                    HorizontalLayout {
                                        padding-left: 4px; padding-right: 36px; padding-top: 8px; padding-bottom: 8px; spacing: 10px; alignment: start;
                                        Rectangle {
                                            width: 48px; height: 48px; border-radius: 4px; clip: true;
                                            background: #2a2a2a;
                                            if item.has-thumbnail: Image {
                                                source: item.thumbnail; width: parent.width; height: parent.height; image-fit: cover;
                                            }
                                            if !item.has-thumbnail: Text {
                                                text: item.avatar-letter;
                                                color: item.video-id == now-playing-video-id ? #1db954 : #6a6a6a;
                                                font-size: 14px; font-weight: 700;
                                                horizontal-alignment: center; vertical-alignment: center;
                                            }
                                        }
                                        VerticalLayout {
                                            alignment: center; spacing: 3px; horizontal-stretch: 1;
                                            Text { text: item.title; font-size: 14px; font-weight: 500; color: item.video-id == now-playing-video-id ? #1db954 : #e0e0e0; overflow: elide; }
                                            Text { text: item.artist; font-size: 12px; color: #6a6a6a; overflow: elide; }
                                        }
                                    }
                                    qrow-ta := TouchArea {
                                        clicked => { play-song(item.video-id, item.title, item.artist, item.duration-secs); }
                                        pointer-event(e) => {
                                            if e.button == PointerEventButton.right && e.kind == PointerEventKind.up {
                                                qrow-ctx.show();
                                            }
                                        }
                                    }
                                    // Remove button on top of touch area (positioned absolutely)
                                    if qrow-ta.has-hover: Rectangle {
                                        x: parent.width - 36px; y: 18px;
                                        width: 28px; height: 28px; border-radius: 14px;
                                        background: rm-ta.has-hover ? #ffffff20 : #ffffff0a;
                                        Image { source: @image-url("icons/close.svg"); width: 14px; height: 14px; colorize: rm-ta.has-hover ? #ffffff : #a0a0a0; x: 7px; y: 7px; }
                                        rm-ta := TouchArea { clicked => { remove-from-queue(i); } }
                                    }
                                    qrow-ctx := PopupWindow {
                                        x: 60px; y: 10px; width: 220px; height: 100px;
                                        Rectangle {
                                            width: 220px; height: 100px;
                                            border-radius: 8px; background: #282828;
                                            drop-shadow-blur: 16px; drop-shadow-color: #00000080; drop-shadow-offset-y: 4px;
                                            VerticalLayout {
                                                padding: 6px;
                                                Rectangle {
                                                    height: 40px; border-radius: 4px;
                                                    background: qctx1.has-hover ? #ffffff14 : transparent;
                                                    HorizontalLayout {
                                                        padding-left: 14px; spacing: 12px; alignment: start;
                                                        Text { text: "✕"; font-size: 14px; color: #b0b0b0; vertical-alignment: center; width: 20px; }
                                                        Text { text: "Remove from queue"; font-size: 14px; font-weight: 500; color: #e0e0e0; vertical-alignment: center; }
                                                    }
                                                    qctx1 := TouchArea { clicked => { remove-from-queue(i); qrow-ctx.close(); } }
                                                }
                                                Rectangle {
                                                    height: 40px; border-radius: 4px;
                                                    background: qctx2.has-hover ? #ffffff14 : transparent;
                                                    HorizontalLayout {
                                                        padding-left: 14px; spacing: 12px; alignment: start;
                                                        Image { source: @image-url("icons/play.svg"); width: 16px; height: 16px; colorize: #b0b0b0; vertical-alignment: center; }
                                                        Text { text: "Play"; font-size: 14px; font-weight: 500; color: #e0e0e0; vertical-alignment: center; }
                                                    }
                                                    qctx2 := TouchArea { clicked => { play-song(item.video-id, item.title, item.artist, item.duration-secs); qrow-ctx.close(); } }
                                                }
                                            }
                                        }
                                    }
                                }
                                if queue.length == 0: Rectangle {
                                    height: 100px;
                                    Text { text: "Queue is empty"; font-size: 14px; color: #4a4a4a; horizontal-alignment: center; vertical-alignment: center; }
                                }

                                // ── Autoplay section ──
                                Rectangle { height: 16px; }
                                Rectangle { height: 1px; background: #1a1a1a; }
                                HorizontalLayout {
                                    height: 44px; padding-left: 4px; padding-right: 4px;
                                    Text {
                                        text: "Autoplay";
                                        font-size: 15px; font-weight: 600;
                                        color: #b0b0b0;
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                    }
                                    Rectangle {
                                        width: 44px; height: 24px; border-radius: 12px;
                                        background: autoplay-enabled ? #1db954 : #3a3a3a;
                                        animate background { duration: 200ms; }
                                        Rectangle {
                                            x: autoplay-enabled ? parent.width - self.width - 3px : 3px;
                                            y: 3px;
                                            width: 18px; height: 18px; border-radius: 9px;
                                            background: #ffffff;
                                            animate x { duration: 200ms; easing: ease-in-out; }
                                        }
                                        TouchArea { clicked => { set-autoplay-enabled(!autoplay-enabled); } }
                                    }
                                }
                                if autoplay-enabled && autoplay-queue.length > 0: VerticalLayout {
                                    spacing: 0px;
                                    for item[i] in autoplay-queue: Rectangle {
                                        height: 64px;
                                        border-radius: 6px;
                                        background: ap-row-ta.has-hover ? #ffffff0a : transparent;
                                        HorizontalLayout {
                                            padding-left: 4px; padding-right: 4px; padding-top: 8px; padding-bottom: 8px; spacing: 10px; alignment: start;
                                            Rectangle {
                                                width: 48px; height: 48px; border-radius: 4px; clip: true;
                                                background: #2a2a2a;
                                                if item.has-thumbnail: Image {
                                                    source: item.thumbnail; width: parent.width; height: parent.height; image-fit: cover;
                                                }
                                                if !item.has-thumbnail: Text {
                                                    text: item.avatar-letter;
                                                    color: #6a6a6a;
                                                    font-size: 14px; font-weight: 700;
                                                    horizontal-alignment: center; vertical-alignment: center;
                                                }
                                            }
                                            VerticalLayout {
                                                alignment: center; spacing: 3px; horizontal-stretch: 1;
                                                Text { text: item.title; font-size: 14px; font-weight: 500; color: #e0e0e0; overflow: elide; }
                                                Text { text: item.artist; font-size: 12px; color: #6a6a6a; overflow: elide; }
                                            }
                                            if ap-row-ta.has-hover: Rectangle {
                                                width: 28px; height: 28px; border-radius: 14px;
                                                background: ap-rm-ta.has-hover ? #ffffff14 : transparent;
                                                Text { text: "✕"; color: #6a6a6a; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
                                                ap-rm-ta := TouchArea { clicked => { remove-from-autoplay(i); } }
                                            }
                                        }
                                        ap-row-ta := TouchArea {
                                            clicked => { play-autoplay-song(i); }
                                            pointer-event(e) => {
                                                if e.button == PointerEventButton.right && e.kind == PointerEventKind.up {
                                                    ap-ctx.show();
                                                }
                                            }
                                        }
                                        ap-ctx := PopupWindow {
                                            x: 60px; y: 10px; width: 220px;
                                            Rectangle {
                                                width: 220px; height: 156px;
                                                border-radius: 8px; background: #282828;
                                                drop-shadow-blur: 16px; drop-shadow-color: #00000080; drop-shadow-offset-y: 4px;
                                                VerticalLayout {
                                                    padding: 6px;
                                                    Rectangle {
                                                        height: 38px; border-radius: 4px;
                                                        background: apctx1.has-hover ? #ffffff14 : transparent;
                                                        HorizontalLayout {
                                                            padding-left: 14px; spacing: 12px; alignment: start;
                                                            Image { source: @image-url("icons/play.svg"); width: 16px; height: 16px; colorize: #b0b0b0; vertical-alignment: center; }
                                                            Text { text: "Play"; font-size: 14px; font-weight: 500; color: #e0e0e0; vertical-alignment: center; }
                                                        }
                                                        apctx1 := TouchArea { clicked => { play-autoplay-song(i); ap-ctx.close(); } }
                                                    }
                                                    Rectangle {
                                                        height: 38px; border-radius: 4px;
                                                        background: apctx2.has-hover ? #ffffff14 : transparent;
                                                        HorizontalLayout {
                                                            padding-left: 14px; spacing: 12px; alignment: start;
                                                            Text { text: "+"; font-size: 18px; color: #b0b0b0; vertical-alignment: center; width: 20px; }
                                                            Text { text: "Add to queue"; font-size: 14px; font-weight: 500; color: #e0e0e0; vertical-alignment: center; }
                                                        }
                                                        apctx2 := TouchArea { clicked => { queue-song(item.video-id, item.title, item.artist); ap-ctx.close(); } }
                                                    }
                                                    Rectangle {
                                                        height: 38px; border-radius: 4px;
                                                        background: apctx3.has-hover ? #ffffff14 : transparent;
                                                        HorizontalLayout {
                                                            padding-left: 14px; spacing: 12px; alignment: start;
                                                            Image { source: @image-url("icons/next.svg"); width: 16px; height: 16px; colorize: #b0b0b0; vertical-alignment: center; }
                                                            Text { text: "Play next"; font-size: 14px; font-weight: 500; color: #e0e0e0; vertical-alignment: center; }
                                                        }
                                                        apctx3 := TouchArea { clicked => { play-next-song(item.video-id, item.title, item.artist, item.duration-secs); ap-ctx.close(); } }
                                                    }
                                                    Rectangle {
                                                        height: 38px; border-radius: 4px;
                                                        background: apctx4.has-hover ? #ffffff14 : transparent;
                                                        HorizontalLayout {
                                                            padding-left: 14px; spacing: 12px; alignment: start;
                                                            Text { text: "✕"; font-size: 14px; color: #b0b0b0; vertical-alignment: center; width: 20px; }
                                                            Text { text: "Remove"; font-size: 14px; font-weight: 500; color: #e0e0e0; vertical-alignment: center; }
                                                        }
                                                        apctx4 := TouchArea { clicked => { remove-from-autoplay(i); ap-ctx.close(); } }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // ── Player bar ────────────────────────────────────────────────
            Rectangle {
                height: 90px;
                background: #0a0a0a;
                Rectangle { x: 0; y: 0; height: 1px; width: parent.width; background: #1a1a1a; }

                HorizontalLayout {
                    padding-left: 20px; padding-right: 20px; padding-top: 15px; padding-bottom: 15px;

                    // Now playing info (left)
                    HorizontalLayout {
                        width: 300px; spacing: 12px; alignment: start;

                        if has-album-art: Rectangle {
                            width: 60px; height: 60px; border-radius: 8px; clip: true;
                            Image { source: album-art; width: parent.width; height: parent.height; image-fit: cover; }
                        }
                        if !has-album-art: Rectangle {
                            width: 60px; height: 60px; border-radius: 8px;
                            background: #1a1a1a;
                            Text {
                                text: track-initial; color: is-playing ? #e85d5d : #4a4a4a;
                                font-size: 20px; font-weight: 700;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                        }

                        VerticalLayout {
                            alignment: center; spacing: 4px; horizontal-stretch: 1;
                            Text { text: track-title; font-size: 14px; font-weight: 600; color: #ffffff; overflow: elide; }
                            Text { text: track-artist; font-size: 12px; color: #6a6a6a; overflow: elide; }
                        }

                        Rectangle {
                            width: 36px; height: 36px;
                            property <bool> like-bounce: false;
                            like-heart := Image {
                                source: @image-url("icons/heart.svg");
                                width: like-bounce ? 28px : (is-liked ? 22px : 20px);
                                height: like-bounce ? 28px : (is-liked ? 22px : 20px);
                                colorize: is-liked ? #e85d5d : #4a4a4a;
                                x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2;
                                animate colorize { duration: 200ms; }
                                animate width, height { duration: 150ms; easing: ease-out-back; }
                            }
                            TouchArea { clicked => { like-bounce = true; like-current(); like-bounce = false; } }
                        }
                    }

                    // Transport + progress (center)
                    VerticalLayout {
                        horizontal-stretch: 1; spacing: 6px; alignment: center;

                        HorizontalLayout {
                            alignment: center; spacing: 16px;
                            Rectangle {
                                width: 32px; height: 32px; border-radius: 16px;
                                background: shuf-ta.has-hover ? #ffffff0c : transparent;
                                Image { source: @image-url("icons/shuffle.svg"); width: 16px; height: 16px; colorize: shuf-ta.has-hover ? #ffffff : #4a4a4a; x: 8px; y: 8px; }
                                shuf-ta := TouchArea { }
                            }
                            Rectangle {
                                width: 36px; height: 36px; border-radius: 18px;
                                background: prev-ta.has-hover ? #ffffff0c : transparent;
                                Image { source: @image-url("icons/prev.svg"); width: 20px; height: 20px; colorize: prev-ta.has-hover ? #ffffff : #b0b0b0; x: 8px; y: 8px; }
                                prev-ta := TouchArea { clicked => { prev-track(); } }
                            }
                            Rectangle {
                                width: 44px; height: 44px; border-radius: 22px;
                                background: #ffffff;
                                if is-playing: Image { source: @image-url("icons/pause.svg"); width: 20px; height: 20px; colorize: #000000; x: 12px; y: 12px; }
                                if !is-playing: Image { source: @image-url("icons/play.svg"); width: 20px; height: 20px; colorize: #000000; x: 13px; y: 12px; }
                                TouchArea { clicked => { toggle-play-pause(); } }
                            }
                            Rectangle {
                                width: 36px; height: 36px; border-radius: 18px;
                                background: next-ta.has-hover ? #ffffff0c : transparent;
                                Image { source: @image-url("icons/next.svg"); width: 20px; height: 20px; colorize: next-ta.has-hover ? #ffffff : #b0b0b0; x: 8px; y: 8px; }
                                next-ta := TouchArea { clicked => { next-track(); } }
                            }
                            Rectangle {
                                width: 32px; height: 32px; border-radius: 16px;
                                background: rep-ta.has-hover ? #ffffff0c : transparent;
                                Image { source: @image-url("icons/repeat.svg"); width: 16px; height: 16px; colorize: rep-ta.has-hover ? #ffffff : #4a4a4a; x: 8px; y: 8px; }
                                rep-ta := TouchArea { }
                            }
                        }

                        // Progress bar
                        HorizontalLayout {
                            spacing: 10px;
                            padding-left: 16px; padding-right: 16px;

                            Text { text: current-time; font-size: 11px; font-weight: 500; color: #6a6a6a; width: 36px; horizontal-alignment: right; }

                            prog-ta := TouchArea {
                                horizontal-stretch: 1; height: 14px;
                                clicked => { seek(self.mouse-x / self.width); }
                                moved  => { seek(self.mouse-x / self.width); }
                                Rectangle {
                                    x: 0; y: (parent.height - self.height) / 2;
                                    height: prog-ta.has-hover ? 5px : 3px;
                                    width: parent.width; border-radius: 2px;
                                    background: #2a2a2a;
                                    Rectangle {
                                        x: 0; y: 0;
                                        width: parent.width * progress;
                                        height: parent.height; border-radius: 2px;
                                        background: prog-ta.has-hover ? #e85d5d : #ffffff;
                                    }
                                }
                                if prog-ta.has-hover: Rectangle {
                                    x: prog-ta.width * progress - 6px;
                                    y: (prog-ta.height - 12px) / 2;
                                    width: 12px; height: 12px; border-radius: 6px;
                                    background: #ffffff;
                                }
                            }

                            Text { text: total-time; font-size: 11px; font-weight: 500; color: #6a6a6a; width: 36px; }
                        }
                    }

                    // Volume + queue toggle (right)
                    HorizontalLayout {
                        width: 220px; spacing: 10px; alignment: end;

                        IconBtn { svg-icon: @image-url("icons/queue.svg"); use-svg: true; active: queue-pane-open; icon-color: queue-pane-open ? #ffffff : #4a4a4a; clicked => { toggle-queue-pane(); } }

                        HorizontalLayout {
                            spacing: 8px; alignment: center;
                            Image { source: @image-url("icons/volume.svg"); width: 18px; height: 18px; colorize: #5a5a5a; vertical-alignment: center; }

                            vol-ta := TouchArea {
                                width: 80px; height: 16px;
                                clicked => { set-volume(self.mouse-x / self.width); }
                                moved  => { set-volume(self.mouse-x / self.width); }
                                Rectangle {
                                    x: 0;
                                    y: (parent.height - self.height) / 2;
                                    height: vol-ta.has-hover ? 5px : 3px;
                                    width: parent.width; border-radius: 2px;
                                    background: #2a2a2a;
                                    Rectangle {
                                        x: 0; y: 0;
                                        width: parent.width * volume;
                                        height: parent.height; border-radius: 2px;
                                        background: vol-ta.has-hover ? #ffffff : #a0a0a0;
                                    }
                                }
                                if vol-ta.has-hover: Rectangle {
                                    x: parent.width * volume - 5px;
                                    y: parent.height / 2 - 5px;
                                    width: 10px; height: 10px; border-radius: 5px;
                                    background: #ffffff;
                                }
                            }
                        }
                    }
                }
            }

        } // VerticalLayout
    } // FocusScope

    // Dismiss overlay (covers entire window, behind dropdown)
    if search-dropdown-open && search-suggestions.length > 0: Rectangle {
        x: 0; y: 0; width: root.width; height: root.height;
        background: transparent;
        TouchArea { clicked => { search-dropdown-open = false; } }
    }

    // Search suggestions dropdown (top z-order, above all content)
    if search-dropdown-open && search-suggestions.length > 0: Rectangle {
        x: search-bar-rect.absolute-position.x;
        y: 52px;
        width: 420px; height: 348px;
        border-radius: 12px; background: #1e1e1e;
        border-color: #ffffff10; border-width: 1px;
        drop-shadow-blur: 20px; drop-shadow-color: #000000a0; drop-shadow-offset-y: 8px;
        clip: true;
        VerticalLayout {
            padding: 8px; spacing: 0px;
            for item[i] in search-suggestions: Rectangle {
                height: 56px; border-radius: 6px;
                background: sug-ta.has-hover ? #ffffff0c : transparent;
                HorizontalLayout {
                    padding-left: 10px; padding-right: 10px; padding-top: 6px; padding-bottom: 6px; spacing: 12px; alignment: start;
                    Rectangle {
                        width: 44px; height: 44px; border-radius: 6px; clip: true;
                        background: #2a2a2a;
                        if item.has-thumbnail: Image { source: item.thumbnail; width: parent.width; height: parent.height; image-fit: cover; }
                        if !item.has-thumbnail: Text { text: item.avatar-letter; color: #6a6a6a; font-size: 14px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                    }
                    VerticalLayout {
                        alignment: center; spacing: 3px; horizontal-stretch: 1;
                        Text { text: item.title; font-size: 14px; font-weight: 500; color: #e0e0e0; overflow: elide; }
                        Text { text: "Song \u{2022} " + item.artist; font-size: 12px; color: #6a6a6a; overflow: elide; }
                    }
                }
                sug-ta := TouchArea {
                    clicked => { play-song(item.video-id, item.title, item.artist, item.duration-secs); search-dropdown-open = false; search-inp.text = ""; live-search(""); }
                    pointer-event(e) => {
                        if (e.button == PointerEventButton.right && e.kind == PointerEventKind.up) {
                            sug-ctx.show();
                        }
                    }
                }
                sug-ctx := PopupWindow {
                    x: sug-ta.mouse-x; y: sug-ta.mouse-y;
                    width: 180px;
                    Rectangle {
                        background: #2a2a2a; border-radius: 8px; border-color: #ffffff15; border-width: 1px;
                        drop-shadow-blur: 12px; drop-shadow-color: #00000080;
                        VerticalLayout {
                            padding: 6px; spacing: 2px;
                            Rectangle {
                                height: 34px; border-radius: 6px;
                                background: ctx-play-ta.has-hover ? #ffffff10 : transparent;
                                HorizontalLayout { padding-left: 12px; alignment: start; spacing: 8px;
                                    Text { text: "\u{25B6}"; font-size: 13px; color: #e0e0e0; vertical-alignment: center; }
                                    Text { text: "Play"; font-size: 13px; color: #e0e0e0; vertical-alignment: center; }
                                }
                                ctx-play-ta := TouchArea { clicked => { play-song(item.video-id, item.title, item.artist, item.duration-secs); search-dropdown-open = false; search-inp.text = ""; live-search(""); } }
                            }
                            Rectangle {
                                height: 34px; border-radius: 6px;
                                background: ctx-queue-ta.has-hover ? #ffffff10 : transparent;
                                HorizontalLayout { padding-left: 12px; alignment: start; spacing: 8px;
                                    Text { text: "\u{2795}"; font-size: 13px; color: #e0e0e0; vertical-alignment: center; }
                                    Text { text: "Add to queue"; font-size: 13px; color: #e0e0e0; vertical-alignment: center; }
                                }
                                ctx-queue-ta := TouchArea { clicked => { queue-song(item.video-id, item.title, item.artist); } }
                            }
                        }
                    }
                }
            }
        }
    }

    // ── First-run onboarding popup (add-on installation) ──────────────────────
    if show-onboarding: Rectangle {
        x: 0; y: 0; width: root.width; height: root.height;
        // Scrim — captures clicks so the app behind stays inert (does not dismiss).
        background: #000000a0;
        TouchArea { }

        ob-card := Rectangle {
            width: min(480px, root.width - 48px);
            height: ob-layout.preferred-height;
            x: (root.width - self.width) / 2;
            y: (root.height - self.height) / 2;
            border-radius: 18px;
            background: #141414;
            border-color: #262626; border-width: 1px;
            drop-shadow-blur: 40px; drop-shadow-color: #000000c0; drop-shadow-offset-y: 16px;

            ob-layout := VerticalLayout {
                padding: 28px; spacing: 18px;

                // Header
                HorizontalLayout {
                    spacing: 14px; alignment: start;
                    Rectangle {
                        width: 46px; height: 46px; border-radius: 12px; background: #e85d5d1a;
                        Text { text: "\u{25B6}"; color: #e85d5d; font-size: 22px; horizontal-alignment: center; vertical-alignment: center; }
                    }
                    VerticalLayout {
                        alignment: center; spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Welcome to Auricle"; font-size: 19px; font-weight: 700; color: #ffffff; }
                        Text { text: "Set up the tools needed for audio playback."; font-size: 13px; color: #8a8a8a; }
                    }
                }

                Text {
                    text: "These optional third-party tools are not bundled with Auricle. Installing them is at your own discretion; Auricle is not affiliated with them. You may also install them manually onto your PATH.";
                    font-size: 12px; color: #6a6a6a; wrap: word-wrap;
                }

                // yt-dlp row
                Rectangle {
                    border-radius: 12px; background: #0e0e0e; border-color: #1d1d1d; border-width: 1px;
                    VerticalLayout {
                        padding: 16px; spacing: 12px;
                        HorizontalLayout {
                            spacing: 12px;
                            VerticalLayout {
                                alignment: center; spacing: 2px; horizontal-stretch: 1;
                                Text { text: "yt-dlp"; font-size: 14px; font-weight: 600; color: #e0e0e0; }
                                Text { text: "Required for audio streaming and downloads."; font-size: 12px; color: #5a5a5a; }
                            }
                            if ytdlp-installed && addon-installing != "ytdlp": Text { text: "\u{2713} Installed"; font-size: 13px; color: #4a9d5a; vertical-alignment: center; }
                            if !ytdlp-installed && addon-installing != "ytdlp": Rectangle {
                                width: 100px; height: 34px; border-radius: 8px;
                                background: addon-busy ? #181818 : (ob-yt-ta.has-hover ? #f06a6a : #e85d5d);
                                animate background { duration: 100ms; }
                                Text { text: "Install"; font-size: 13px; font-weight: 600; color: addon-busy ? #5a5a5a : #ffffff; horizontal-alignment: center; vertical-alignment: center; }
                                ob-yt-ta := TouchArea { clicked => { if !addon-busy { install-ytdlp(); } } }
                            }
                        }
                        if addon-installing == "ytdlp": VerticalLayout {
                            spacing: 6px;
                            AddonProgress { value: addon-progress; }
                            Text {
                                text: addon-progress < 0 ? "Installing\u{2026}" : (Math.round(addon-progress * 100) + "%");
                                font-size: 11px; color: #8a8a8a;
                            }
                        }
                    }
                }

                // ffmpeg row
                Rectangle {
                    border-radius: 12px; background: #0e0e0e; border-color: #1d1d1d; border-width: 1px;
                    VerticalLayout {
                        padding: 16px; spacing: 12px;
                        HorizontalLayout {
                            spacing: 12px;
                            VerticalLayout {
                                alignment: center; spacing: 2px; horizontal-stretch: 1;
                                Text { text: "ffmpeg"; font-size: 14px; font-weight: 600; color: #e0e0e0; }
                                Text { text: "Optional \u{2022} improves format handling for downloads."; font-size: 12px; color: #5a5a5a; }
                            }
                            if ffmpeg-installed && addon-installing != "ffmpeg": Text { text: "\u{2713} Installed"; font-size: 13px; color: #4a9d5a; vertical-alignment: center; }
                            if !ffmpeg-installed && addon-installing != "ffmpeg": Rectangle {
                                width: 100px; height: 34px; border-radius: 8px;
                                background: addon-busy ? #181818 : (ob-ff-ta.has-hover ? #333333 : #2a2a2a);
                                animate background { duration: 100ms; }
                                Text { text: "Install"; font-size: 13px; font-weight: 600; color: addon-busy ? #5a5a5a : #ffffff; horizontal-alignment: center; vertical-alignment: center; }
                                ob-ff-ta := TouchArea { clicked => { if !addon-busy { install-ffmpeg(); } } }
                            }
                        }
                        if addon-installing == "ffmpeg": VerticalLayout {
                            spacing: 6px;
                            AddonProgress { value: addon-progress; }
                            Text {
                                text: addon-progress < 0 ? "Installing\u{2026}" : (Math.round(addon-progress * 100) + "%");
                                font-size: 11px; color: #8a8a8a;
                            }
                        }
                    }
                }

                if addon-status != "": Text { text: addon-status; font-size: 12px; color: #8a8a8a; wrap: word-wrap; horizontal-alignment: center; }

                // Footer
                HorizontalLayout {
                    alignment: center;
                    Rectangle {
                        width: ob-done-txt.preferred-width + 36px; height: 36px; border-radius: 8px;
                        background: ob-done-ta.has-hover ? #ffffff14 : transparent;
                        animate background { duration: 100ms; }
                        ob-done-txt := Text {
                            text: ytdlp-installed ? "Done" : "Maybe later";
                            font-size: 13px; font-weight: 600;
                            color: addon-busy ? #4a4a4a : #b0b0b0;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                        ob-done-ta := TouchArea { clicked => { if !addon-busy { dismiss-onboarding(); } } }
                    }
                }
            }
        }
    }
}
