{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Auricle",
  "version": "0.1.0",
  "identifier": "com.auricle.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Auricle",
        "width": 1280,
        "height": 800,
        "backgroundColor": "#0f1523",
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "schemes": ["com.googleusercontent.apps.363288825229-jlbiuir8ds26t7mt7jkdneqpq6o0s639"]
    },
    "single-instance": null
  }
}
